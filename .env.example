PORT=3000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=twitch_chat_stats
# Separate database (same Mongo server) for web-only data the bot never reads:
# sessions, site preferences, cached Twitch profile data (avatar/chat color).
WEB_MONGODB_DB=chatwizardbot_web

SESSION_SECRET=change_me_to_a_long_random_string

# Register a SEPARATE Twitch Developer Console app for this website
# (do not reuse the bot's Client_Id/client_secret from the TwitchBot repo).
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/auth/callback

# Comma-separated numeric Twitch user IDs granted tier-0 (app developer) access.
ADMIN_USER_IDS=