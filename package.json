{
  "name": "twitchbot-web",
  "version": "0.1.0",
  "description": "Web control panel for the Twitch chat bot (separate repo, shared MongoDB integration).",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "dev:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "connect-mongo": "^5.1.0",
    "dotenv": "^17.2.1",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.0",
    "helmet": "^8.2.0",
    "mongodb": "^6.18.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "nodemon": "^3.1.4",
    "tailwindcss": "^4.0.0"
  }
}
