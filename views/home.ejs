<%- include('partials/head', { title: t('home.title') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-5xl mx-auto px-6">
  <section class="py-20 text-center">
    <h1 class="text-4xl font-bold text-neutral-100 tracking-tight"><%= t('home.title') %></h1>
    <p class="mt-4 text-neutral-400 max-w-xl mx-auto">
      <%= t('home.subtitle') %>
    </p>
  </section>

  <%# data-stat keys match /stats.json's response; data-value carries the raw number so
      public/js/home-stats.js can rebuild the odometer digits without parsing formatted text.
      Values are locale-formatted with the SAME locale the client script uses (the page's),
      so the first poll never "changes" a number that is actually equal. %>
  <%
    const statTiles = [
      { key: 'commandsExecuted', label: t('home.statCommandsExecuted'), value: commandsExecuted },
      { key: 'emotesUsed', label: t('home.statEmotesUsed'), value: emoteStats.totalUsageCount },
      { key: 'emotesTracked', label: t('home.statEmotesTracked'), value: emoteStats.totalEntriesAdded },
      { key: 'uniqueUsers', label: t('home.statUniqueUsers'), value: uniqueUsers },
    ];
  %>
  <section class="grid grid-cols-2 sm:grid-cols-4 gap-4 pb-16">
    <% statTiles.forEach(function(tile) { %>
      <div class="rounded-lg border border-neutral-800 bg-neutral-900 p-4">
        <p class="text-neutral-500 text-xs uppercase tracking-wide"><%= tile.label %></p>
        <p class="text-2xl font-semibold text-neutral-100 mt-1 tabular-nums"
           data-stat="<%= tile.key %>" data-value="<%= tile.value %>"><%= tile.value.toLocaleString(locale) %></p>
      </div>
    <% }) %>
  </section>

  <section class="pb-24">
    <h2 class="text-lg font-semibold text-neutral-100 mb-4"><%= t('home.channelsHeading') %></h2>
    <% if (channels.length === 0) { %>
      <p class="text-neutral-500 text-sm"><%= t('home.noChannels') %></p>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <% channels.forEach(function(ch) { %>
          <a href="/<%= ch.channelLogin %>/statistics/chat" class="block rounded-lg border border-neutral-800 hover:border-purple-600/60 bg-neutral-900 hover:bg-neutral-900/70 p-5 transition-colors group">
            <h3 class="font-medium text-neutral-100 group-hover:text-purple-300 transition-colors"><%= ch.channelLogin %></h3>
            <p class="text-xs text-neutral-500 mt-1"><%= t('home.viewStatistics') %> →</p>
          </a>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<script src="/js/home-stats.js" defer></script>
<%- include('partials/foot') %>
