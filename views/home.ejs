<%- include('partials/head', { title: t('home.title') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-5xl mx-auto px-6">
  <section class="py-20 text-center">
    <h1 class="text-4xl font-bold text-neutral-100 tracking-tight"><%= t('home.title') %></h1>
    <p class="mt-4 text-neutral-400 max-w-xl mx-auto">
      <%= t('home.subtitle') %>
    </p>
  </section>

  <section class="grid grid-cols-2 sm:grid-cols-4 gap-4 pb-16">
    <div class="rounded-lg border border-neutral-800 bg-neutral-900 p-4">
      <p class="text-neutral-500 text-xs uppercase tracking-wide"><%= t('home.statCommandsExecuted') %></p>
      <p class="text-2xl font-semibold text-neutral-100 mt-1"><%= commandsExecuted.toLocaleString() %></p>
    </div>
    <div class="rounded-lg border border-neutral-800 bg-neutral-900 p-4">
      <p class="text-neutral-500 text-xs uppercase tracking-wide"><%= t('home.statEmotesUsed') %></p>
      <p class="text-2xl font-semibold text-neutral-100 mt-1"><%= emoteStats.totalUsageCount.toLocaleString() %></p>
    </div>
    <div class="rounded-lg border border-neutral-800 bg-neutral-900 p-4">
      <p class="text-neutral-500 text-xs uppercase tracking-wide"><%= t('home.statEmotesTracked') %></p>
      <p class="text-2xl font-semibold text-neutral-100 mt-1"><%= emoteStats.totalEntriesAdded.toLocaleString() %></p>
    </div>
    <div class="rounded-lg border border-neutral-800 bg-neutral-900 p-4">
      <p class="text-neutral-500 text-xs uppercase tracking-wide"><%= t('home.statUniqueUsers') %></p>
      <p class="text-2xl font-semibold text-neutral-100 mt-1"><%= uniqueUsers.toLocaleString() %></p>
    </div>
  </section>

  <section class="pb-24">
    <h2 class="text-lg font-semibold text-neutral-100 mb-4"><%= t('home.channelsHeading') %></h2>
    <% if (channels.length === 0) { %>
      <p class="text-neutral-500 text-sm"><%= t('home.noChannels') %></p>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <% channels.forEach(function(ch) { %>
          <a href="/<%= ch.channelLogin %>" class="block rounded-lg border border-neutral-800 hover:border-purple-600/60 bg-neutral-900 hover:bg-neutral-900/70 p-5 transition-colors group">
            <h3 class="font-medium text-neutral-100 group-hover:text-purple-300 transition-colors"><%= ch.channelLogin %></h3>
            <p class="text-xs text-neutral-500 mt-1"><%= t('home.viewStatistics') %> →</p>
          </a>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<%- include('partials/foot') %>
