<%- include('partials/head', { title: t('games.backgammon.name') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-4xl mx-auto px-4 sm:px-6 py-6">
  <div class="mb-4 flex items-baseline justify-between gap-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-neutral-100"><%= t('games.backgammon.name') %></h1>
    <a href="/games" class="text-sm text-purple-400 hover:text-purple-300 shrink-0">&larr; <%= t('games.backgammon.backToGames') %></a>
  </div>

  <div id="bg-root" data-ws-path="/ws/backgammon" class="max-w-3xl mx-auto">
    <div id="bg-screen-idle" class="rounded-xl border border-neutral-800 bg-neutral-900 p-8 text-center">
      <p class="text-neutral-400 mb-4"><%= t('games.backgammon.intro') %></p>
      <button type="button" id="bg-queue-button"
              class="px-6 py-3 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors"><%= t('games.quickMatch.findOpponent') %></button>
    </div>

    <div id="bg-screen-queued" hidden class="rounded-xl border border-neutral-800 bg-neutral-900 p-8 text-center">
      <p class="text-neutral-300 mb-2"><%= t('games.quickMatch.searchingForOpponent') %></p>
      <p class="text-sm text-neutral-500 mb-1"><%= t('games.quickMatch.playersSearching') %>: <span id="bg-queue-count" class="tabular-nums text-neutral-200">1</span></p>
      <p class="text-sm text-neutral-500 mb-6"><%= t('games.quickMatch.searchTime') %>: <span id="bg-queue-time" class="tabular-nums text-neutral-200">0:00</span></p>
      <button type="button" id="bg-cancel-queue"
              class="px-5 py-2.5 rounded-lg text-neutral-300 hover:bg-neutral-800 transition-colors"><%= t('games.quickMatch.cancelSearch') %></button>
    </div>

    <div id="bg-screen-game" hidden>
      <div id="bg-opponent-banner" hidden class="mb-3 px-4 py-2 rounded-lg bg-amber-500/15 text-amber-300 text-sm text-center">
        <%= t('games.quickMatch.opponentDisconnected') %>
      </div>

      <div class="flex items-center justify-between gap-3 mb-3">
        <span id="bg-color-badge" hidden
              data-p0="<%= t('games.backgammon.youAreWhite') %>"
              data-p1="<%= t('games.backgammon.youAreBlack') %>"
              class="px-2.5 py-1 rounded-md text-sm font-medium"></span>
        <p id="bg-status" class="text-neutral-300"
           data-your-roll="<%= t('games.backgammon.yourRoll') %>"
           data-your-move="<%= t('games.backgammon.yourMove') %>"
           data-opponent-turn="<%= t('games.backgammon.opponentTurn') %>"></p>
        <div class="flex items-center gap-2">
          <span id="bg-timer" hidden class="px-2.5 py-1 rounded-md bg-neutral-800 text-neutral-200 text-sm font-medium tabular-nums"></span>
          <span class="text-xs text-neutral-500"><%= t('games.backgammon.turnNumber') %></span>
          <span id="bg-turn-value" class="w-8 h-8 grid place-items-center rounded bg-neutral-800 text-neutral-100 font-bold tabular-nums">1</span>
        </div>
      </div>

      <div id="bg-board" class="bg-board">
        <div id="bg-quad-tl" class="bg-quad bg-quad-tl"></div>
        <button type="button" id="bg-bar" class="bg-bar-col" title="<%= t('games.backgammon.bar') %>"></button>
        <div id="bg-quad-tr" class="bg-quad bg-quad-tr"></div>
        <div id="bg-quad-bl" class="bg-quad bg-quad-bl"></div>
        <div id="bg-quad-br" class="bg-quad bg-quad-br"></div>
      </div>

      <div class="flex items-center justify-between mt-3 gap-4">
        <div class="rounded-xl border border-neutral-800 bg-neutral-900 px-4 py-2 text-center">
          <p class="text-xs text-neutral-500 mb-1"><%= t('games.backgammon.borneOffYou') %></p>
          <span id="bg-off-0" class="text-lg font-semibold text-neutral-100 tabular-nums">0</span>
        </div>
        <div id="bg-dice" class="flex items-center"></div>
        <button type="button" id="bg-bear-off-zone"
                class="rounded-xl border border-dashed border-neutral-700 px-4 py-2 text-xs text-neutral-500 hover:border-purple-500/50 transition-colors">
          <%= t('games.backgammon.bearOffZone') %>
        </button>
        <div class="rounded-xl border border-neutral-800 bg-neutral-900 px-4 py-2 text-center">
          <p class="text-xs text-neutral-500 mb-1"><%= t('games.backgammon.borneOffOpponent') %></p>
          <span id="bg-off-1" class="text-lg font-semibold text-neutral-100 tabular-nums">0</span>
        </div>
      </div>

      <div class="flex items-center justify-center gap-3 mt-4">
        <button type="button" id="bg-roll" hidden
                class="px-5 py-2.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors"><%= t('games.backgammon.roll') %></button>
        <button type="button" id="bg-resign"
                class="px-4 py-2 rounded-lg text-neutral-400 hover:bg-neutral-800 text-sm transition-colors"><%= t('games.quickMatch.resign') %></button>
      </div>

      <div id="bg-result" hidden class="mt-6 rounded-xl border border-neutral-800 bg-neutral-900 p-8 text-center">
        <h2 id="bg-result-title" data-win="<%= t('games.backgammon.youWin') %>" data-lose="<%= t('games.backgammon.youLose') %>"
            class="text-xl font-semibold text-neutral-100 mb-2"></h2>
        <p id="bg-result-body" data-rating-tpl="<%= t('games.quickMatch.ratingChangeTpl') %>" class="text-sm text-neutral-400 mb-4"></p>
        <button type="button" id="bg-play-again"
                class="px-5 py-2.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors"><%= t('games.backgammon.playAgain') %></button>
      </div>
    </div>
  </div>

  <%# Rating leaderboard - same pattern as the other 3 online games'. %>
  <aside class="max-w-sm mx-auto mt-6 rounded-xl border border-neutral-800 bg-neutral-900 p-4">
    <p class="text-xs uppercase tracking-wide text-neutral-500 mb-2"><%= t('games.backgammon.leaderboardTitle') %></p>
    <ol class="space-y-0.5">
      <% if (leaderboard.rows.length === 0) { %>
        <li class="text-sm text-neutral-500 py-1"><%= t('games.backgammon.leaderboardEmpty') %></li>
      <% } %>
      <% leaderboard.rows.forEach(function(row) { %>
        <li class="flex items-baseline gap-2 text-sm py-1 px-1 rounded<%= row.isMe ? ' bg-purple-500/10' : '' %>">
          <span class="w-5 text-right tabular-nums text-neutral-500 shrink-0"><%= row.rank %></span>
          <span class="flex-1 truncate <%= row.isMe ? 'text-purple-300' : 'text-neutral-300' %>"
                <% if (row.color) { %>style="color: <%= row.color %>"<% } %>><%= row.displayName %></span>
          <span class="tabular-nums text-neutral-100"><%= row.score %></span>
        </li>
      <% }) %>
      <% if (leaderboard.myRow) { %>
        <li class="flex items-baseline gap-2 text-sm py-1 px-1 rounded bg-purple-500/10 mt-1 pt-1 border-t border-neutral-800">
          <span class="w-5 text-right tabular-nums text-neutral-500 shrink-0"><%= leaderboard.myRow.rank %></span>
          <span class="flex-1 truncate text-purple-300"
                <% if (leaderboard.myRow.color) { %>style="color: <%= leaderboard.myRow.color %>"<% } %>><%= leaderboard.myRow.displayName %></span>
          <span class="tabular-nums text-neutral-100"><%= leaderboard.myRow.score %></span>
        </li>
      <% } %>
    </ol>
  </aside>
</main>

<%- include('partials/quickMatchReadyCheck') %>
<script src="/js/games/quickMatchClient.js" defer></script>
<script src="/js/games/backgammon.js" defer></script>
<%- include('partials/foot') %>
