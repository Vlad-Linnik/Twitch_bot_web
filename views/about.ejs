<%- include('partials/head', { title: t('about.title') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-2xl mx-auto px-6 py-16">
  <h1 class="text-3xl font-bold text-neutral-100 mb-6"><%= t('about.title') %></h1>

  <div class="space-y-6 text-neutral-400 leading-relaxed">
    <p>
      <%= t('about.intro') %>
    </p>

    <div>
      <h2 class="text-neutral-200 font-medium mb-1"><%= t('about.creatorHeading') %></h2>
      <p>
        <%# Rendered in the creator's own Twitch chat colour (or their custom override from
            /settings) and linked to their channel. Falls back to a plain purple link if the colour
            couldn't be resolved - see routes/about.js. %>
        <a href="https://twitch.tv/<%= creator.login %>" target="_blank" rel="noopener noreferrer"
           class="font-medium hover:underline underline-offset-2 <%= creator.color ? '' : 'text-purple-400 hover:text-purple-300' %>"
           <% if (creator.color) { %>style="color: <%= creator.color %>"<% } %>>@<%= creator.login %></a>
      </p>
    </div>

    <div>
      <h2 class="text-neutral-200 font-medium mb-1"><%= t('about.supportHeading') %></h2>
      <p>
        <%= t('about.supportText') %>
        <a href="mailto:chatwizardbot.help@gmail.com" class="text-purple-400 hover:text-purple-300">chatwizardbot.help@gmail.com</a>.
      </p>
    </div>
  </div>
</main>

<%- include('partials/foot') %>
