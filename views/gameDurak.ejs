<%- include('partials/head', { title: t('games.durak.name') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-5xl mx-auto px-4 sm:px-6 py-6">
  <div class="mb-4 flex items-baseline justify-between gap-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-neutral-100"><%= t('games.durak.name') %></h1>
    <div class="flex items-baseline gap-4 shrink-0">
      <a href="#" id="durak-back-to-modes" hidden
         class="text-sm text-purple-400 hover:text-purple-300"><%= t('games.durak.backToModeSelect') %></a>
      <a href="/games" class="text-sm text-purple-400 hover:text-purple-300"><%= t('games.durak.backToGames') %></a>
    </div>
  </div>

  <%# --- Mode select: vs computer or with people, both on this one page ------ %>
  <section id="durak-mode-select">
    <div class="grid gap-4 sm:grid-cols-2 max-w-2xl mx-auto">
      <button type="button" id="durak-mode-pc-btn"
              class="text-left rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
        <h2 class="text-lg font-semibold text-neutral-100"><span aria-hidden="true">🤖</span> <%= t('games.durak.modeSelectPc') %></h2>
        <p class="text-sm text-neutral-500 mt-1"><%= t('games.durak.modeSelectPcDesc') %></p>
      </button>

      <% if (user) { %>
        <button type="button" id="durak-mode-people-btn"
                class="text-left rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
          <h2 class="text-lg font-semibold text-neutral-100"><span aria-hidden="true">👥</span> <%= t('games.durak.modeSelectPeople') %></h2>
          <p class="text-sm text-neutral-500 mt-1"><%= t('games.durak.modeSelectPeopleDesc') %></p>
        </button>
      <% } else { %>
        <a href="/auth/login"
           class="block rounded-xl border border-neutral-800 bg-neutral-900 p-5 opacity-70 hover:opacity-100 transition-opacity">
          <h2 class="text-lg font-semibold text-neutral-100"><span aria-hidden="true">👥</span> <%= t('games.durak.modeSelectPeople') %></h2>
          <p class="text-sm text-neutral-500 mt-1"><%= t('games.durak.modeSelectPeopleDesc') %></p>
          <p class="text-xs text-purple-400 mt-2"><%= t('games.durakMultiplayer.loginRequired') %></p>
        </a>
      <% } %>
    </div>

    <%# Online-only rating: multiplayer wins alone (routes/games.js's
        GAME_DURAK_ONLINE) - a vs-computer win never reaches the server, so
        it can never appear here. Server-rendered snapshot, no client JS - it
        only changes when someone finishes a multiplayer game elsewhere. %>
    <aside class="max-w-sm mx-auto mt-6 rounded-xl border border-neutral-800 bg-neutral-900 p-4">
      <p class="text-xs uppercase tracking-wide text-neutral-500 mb-2"><%= t('games.durak.leaderboardTitle') %></p>
      <ol class="space-y-0.5">
        <% if (leaderboard.rows.length === 0) { %>
          <li class="text-sm text-neutral-500 py-1"><%= t('games.durak.leaderboardEmpty') %></li>
        <% } %>
        <% leaderboard.rows.forEach(function(row) { %>
          <li class="flex items-baseline gap-2 text-sm py-1 px-1 rounded<%= row.isMe ? ' bg-purple-500/10' : '' %>">
            <span class="w-5 text-right tabular-nums text-neutral-500 shrink-0"><%= row.rank %></span>
            <span class="flex-1 truncate <%= row.isMe ? 'text-purple-300' : 'text-neutral-300' %>"
                  <% if (row.color) { %>style="color: <%= row.color %>"<% } %>><%= row.displayName %></span>
            <span class="tabular-nums text-neutral-100"><%= row.score %></span>
          </li>
        <% }) %>
        <% if (leaderboard.myRow) { %>
          <li class="flex items-baseline gap-2 text-sm py-1 px-1 rounded bg-purple-500/10 mt-1 pt-1 border-t border-neutral-800">
            <span class="w-5 text-right tabular-nums text-neutral-500 shrink-0"><%= leaderboard.myRow.rank %></span>
            <span class="flex-1 truncate text-purple-300"
                  <% if (leaderboard.myRow.color) { %>style="color: <%= leaderboard.myRow.color %>"<% } %>><%= leaderboard.myRow.displayName %></span>
            <span class="tabular-nums text-neutral-100"><%= leaderboard.myRow.score %></span>
          </li>
        <% } %>
      </ol>
    </aside>
  </section>

  <%# --- Play vs computer -------------------------------------------------- %>
  <section id="durak-pc-section" hidden>
    <div class="flex flex-col sm:flex-row gap-6 items-start justify-center">
      <%# The board is plain DOM, no canvas and no image assets - every card is a
          small styled div built in public/js/games/durak.js from {suit, rank}, same
          "original inline art, no external assets" convention as the other games'
          SVG previews. The overlay (start / win / lose / draw) sits on top; all its
          text is server-rendered here, the client only toggles visibility/labels
          via the data-* attributes below (same pattern as game2048.ejs's overlay). %>
      <div class="relative rounded-xl border border-neutral-800 bg-neutral-900 p-3 sm:p-4 w-full sm:w-[720px] shrink-0">
        <div id="durak-board"
             data-status-attack="<%= t('games.durak.statusYourAttack') %>"
             data-status-throwin="<%= t('games.durak.statusYourThrowIn') %>"
             data-status-defend="<%= t('games.durak.statusYourDefend') %>"
             data-status-opponent="<%= t('games.durak.statusOpponentTurn') %>"
             data-deck-tooltip="<%= t('games.durak.deckTooltip') %>"
             data-trump-label="<%= t('games.durak.trumpLabel') %>"
             data-opponent-tooltip="<%= t('games.durak.opponentTooltip') %>"
             data-toast-you-take="<%= t('games.durak.toastYouTake') %>"
             data-toast-opponent-takes="<%= t('games.durak.toastOpponentTakes') %>"
             data-toast-you-beat="<%= t('games.durak.toastYouBeat') %>"
             data-toast-opponent-beat="<%= t('games.durak.toastOpponentBeat') %>"
             class="relative rounded-lg bg-neutral-950 border border-neutral-800 min-h-[520px] flex flex-col">
          <div class="px-3 pt-3">
            <p class="text-xs uppercase tracking-wide text-neutral-500 mb-1.5"><%= t('games.durak.opponentHand') %></p>
            <div id="durak-opponent-hand" class="flex justify-center gap-1 h-24"></div>
          </div>

          <div class="flex-1 flex items-center gap-3 px-3 py-2">
            <div class="flex flex-col items-center gap-1 shrink-0">
              <div id="durak-deck" class="relative flex items-end gap-1 h-20"></div>
              <span id="durak-deck-count" class="text-xs text-neutral-500 tabular-nums">0</span>
              <%# Stays visible even once the deck (and its rotated trump-card
                  reveal) runs out, so players don't lose track of trump. %>
              <span id="durak-trump-label" class="text-xs font-medium"></span>
            </div>
            <div id="durak-table" class="flex-1 flex flex-wrap justify-center items-center gap-2 min-h-[130px]"></div>
          </div>

          <%# Status text and action buttons live LAST, after the hand, on
              purpose - nothing else in the board renders below them, so no
              amount of table/hand cards wrapping to extra rows above can ever
              grow into and cover them. Keep this the final block in
              #durak-board if the layout above changes. %>
          <div class="px-3 pb-3">
            <p class="text-xs uppercase tracking-wide text-neutral-500 mb-1.5"><%= t('games.durak.yourHand') %></p>
            <div id="durak-player-hand" class="flex flex-wrap justify-center gap-1 min-h-[110px]"></div>
          </div>

          <div class="border-t border-neutral-800 pt-2 pb-3 px-3">
            <p id="durak-status" class="text-center text-sm text-neutral-400 min-h-[1.5em]"></p>
            <div class="flex justify-center gap-3 mt-1">
              <button type="button" id="durak-take-btn" hidden
                      class="px-4 py-1.5 rounded-lg bg-rose-600 hover:bg-rose-500 text-white text-sm font-medium transition-colors"><%= t('games.durak.take') %></button>
              <button type="button" id="durak-bito-btn" hidden
                      class="px-4 py-1.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors"><%= t('games.durak.bito') %></button>
            </div>
          </div>
        </div>

        <div id="durak-overlay"
             data-title-start="<%= t('games.durak.name') %>"
             data-title-win="<%= t('games.durak.win') %>"
             data-title-lose="<%= t('games.durak.lose') %>"
             data-title-draw="<%= t('games.durak.draw') %>"
             data-button-start="<%= t('games.durak.start') %>"
             data-button-again="<%= t('games.durak.playAgain') %>"
             data-final-wins-label="<%= t('games.durak.finalWinsLabel') %>"
             class="absolute inset-3 sm:inset-4 rounded-lg bg-neutral-950/85 backdrop-blur-sm grid place-items-center text-center">
          <div class="px-4">
            <h2 id="durak-overlay-title" class="text-xl font-semibold text-neutral-100 mb-1"></h2>
            <p id="durak-overlay-wins" class="text-sm text-neutral-400 mb-4" hidden></p>
            <button type="button" id="durak-overlay-button"
                    class="px-5 py-2.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-400"></button>
          </div>
        </div>
      </div>

      <div class="w-full sm:w-56 rounded-xl border border-neutral-800 bg-neutral-900 p-4 shrink-0">
        <div class="flex justify-between items-baseline mb-2">
          <span class="text-xs uppercase tracking-wide text-neutral-500"><%= t('games.durak.wins') %></span>
          <span id="durak-wins" class="text-lg font-semibold text-neutral-100 tabular-nums">0</span>
        </div>
        <button type="button" id="durak-newgame"
                class="w-full mt-2 px-3 py-2 rounded-lg bg-neutral-800 hover:bg-neutral-700 text-neutral-200 text-sm font-medium transition-colors"><%= t('games.durak.newGame') %></button>
      </div>
    </div>
  </section>

  <%# --- Play with people --------------------------------------------------- %>
  <section id="durak-people-section" hidden>
    <%# All game state (lobby list, room membership, table) is pushed over the
        WebSocket connection (public/js/games/durak-multiplayer.js) - this is an
        empty shell, same "server renders the frame, client drives visibility"
        pattern the vs-computer section's overlay uses. autoJoinRoomId (from
        routes/games.js's /games/durak/room/:roomId) is read straight off the
        dataset by the client, nothing server-rendered depends on it. %>
    <div id="dmp-root"
         data-ws-path="/ws/durak-multiplayer"
         data-auto-join-room-id="<%= autoJoinRoomId || '' %>"
         data-my-user-id="<%= user ? user.userId : '' %>"
         data-join-label="<%= t('games.durakMultiplayer.joinRoom') %>"
         data-host-prefix="<%= t('games.durakMultiplayer.hostPrefix') %>"
         data-status-connecting="<%= t('games.durakMultiplayer.connecting') %>"
         data-status-reconnecting="<%= t('games.durakMultiplayer.reconnecting') %>"
         data-status-disconnected="<%= t('games.durakMultiplayer.disconnectedFinal') %>"
         data-status-attack="<%= t('games.durakMultiplayer.statusYourAttack') %>"
         data-status-throwin="<%= t('games.durakMultiplayer.statusYourThrowIn') %>"
         data-status-defend="<%= t('games.durakMultiplayer.statusYourDefend') %>"
         data-status-waiting="<%= t('games.durakMultiplayer.statusWaiting') %>"
         data-players-count-tpl="<%= t('games.durakMultiplayer.playersCount', { count: '__COUNT__', max: '__MAX__' }) %>"
         data-ready-accepted-tpl="<%= t('games.durakMultiplayer.readyCheckAcceptedTpl', { accepted: '__ACCEPTED__', total: '__TOTAL__' }) %>"
         data-ready-countdown-tpl="<%= t('games.durakMultiplayer.readyCheckCountdownTpl', { seconds: '__SECONDS__' }) %>"
         data-finish-rank-tpl="<%= t('games.durakMultiplayer.finishRankLabel', { rank: '__RANK__' }) %>"
         data-standings-eliminated-label="<%= t('games.durakMultiplayer.standingsEliminatedLabel') %>"
         data-link-copied="<%= t('games.durakMultiplayer.linkCopied') %>"
         data-err-room-not-found="<%= t('games.durakMultiplayer.errorRoomNotFound') %>"
         data-err-room-full="<%= t('games.durakMultiplayer.errorRoomFull') %>"
         data-err-room-not-joinable="<%= t('games.durakMultiplayer.errorRoomNotJoinable') %>"
         data-err-rate-limited="<%= t('games.durakMultiplayer.errorRateLimited') %>"
         data-err-already-in-room="<%= t('games.durakMultiplayer.errorAlreadyInRoom') %>"
         data-err-not-enough-players="<%= t('games.durakMultiplayer.errorNotEnoughPlayers') %>"
         data-err-not-host="<%= t('games.durakMultiplayer.errorNotHost') %>"
         data-err-generic="<%= t('games.durakMultiplayer.errorGeneric') %>"
         data-title-durak="<%= t('games.durakMultiplayer.durakResultTitle') %>"
         data-title-draw="<%= t('games.durakMultiplayer.drawResultTitle') %>"
         data-left-result-title-tpl="<%= t('games.durakMultiplayer.leftResultTitleTpl', { name: '__NAME__' }) %>"
         data-durak-loser-label="<%= t('games.durakMultiplayer.durakLoserLabel') %>"
         data-winner-label="<%= t('games.durakMultiplayer.winnerLabel') %>"
         data-you-label="<%= t('games.durakMultiplayer.youLabel') %>"
         data-action-pass-tpl="<%= t('games.durakMultiplayer.actionPassTpl', { name: '__NAME__' }) %>"
         data-action-take-tpl="<%= t('games.durakMultiplayer.actionTakeTpl', { name: '__NAME__' }) %>"
         data-action-beaten-tpl="<%= t('games.durakMultiplayer.actionBeatenTpl', { name: '__NAME__' }) %>"
         data-action-transfer-tpl="<%= t('games.durakMultiplayer.actionTransferTpl', { name: '__NAME__' }) %>"
         data-action-timeout-tpl="<%= t('games.durakMultiplayer.actionTimeoutTpl', { name: '__NAME__' }) %>"
         data-time-remaining-tooltip="<%= t('games.durakMultiplayer.timeRemainingTooltip') %>"
         data-trump-label="<%= t('games.durakMultiplayer.trumpLabel') %>">

      <p id="dmp-connstatus" class="text-sm text-neutral-500 mb-3"></p>

      <%# --- Lobby: list of open rooms --------------------------------------- %>
      <section id="dmp-lobby-view">
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs uppercase tracking-wide text-neutral-500"><%= t('games.durakMultiplayer.lobbyTitle') %></p>
          <button type="button" id="dmp-create-room-btn"
                  class="px-4 py-1.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors"><%= t('games.durakMultiplayer.createRoom') %></button>
        </div>
        <ul id="dmp-room-list" class="space-y-2">
          <li id="dmp-room-list-empty" class="text-sm text-neutral-500 py-2"><%= t('games.durakMultiplayer.lobbyEmpty') %></li>
        </ul>

        <div class="mt-8 rounded-xl border border-neutral-800 bg-neutral-900 p-4 max-w-sm">
          <p class="text-xs uppercase tracking-wide text-neutral-500 mb-2"><%= t('games.durakMultiplayer.rulesTitle') %></p>
          <ul class="text-sm text-neutral-400 space-y-1.5 list-disc list-inside">
            <li><%= t('games.durakMultiplayer.mpRule1') %></li>
            <li><%= t('games.durakMultiplayer.mpRule2') %></li>
            <li><%= t('games.durakMultiplayer.mpRule3') %></li>
            <li><%= t('games.durakMultiplayer.mpRule4') %></li>
            <li><%= t('games.durakMultiplayer.mpRule5') %></li>
            <li><%= t('games.durakMultiplayer.mpRule6') %></li>
            <li><%= t('games.durakMultiplayer.mpRule7') %></li>
            <li><%= t('games.durakMultiplayer.mpRule8') %></li>
            <li><%= t('games.durakMultiplayer.mpRule9') %></li>
          </ul>
        </div>
      </section>

      <%# --- Room: header (code/players/start/leave) + table -------------------- %>
      <section id="dmp-room-view" hidden>
        <div class="rounded-xl border border-neutral-800 bg-neutral-900 p-4 mb-4">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
            <div class="flex items-baseline gap-2">
              <span class="text-xs uppercase tracking-wide text-neutral-500"><%= t('games.durakMultiplayer.roomCodeLabel') %></span>
              <span id="dmp-room-code" class="text-sm font-mono text-neutral-200"></span>
              <button type="button" id="dmp-copy-link-btn" class="text-xs text-purple-400 hover:text-purple-300"><%= t('games.durakMultiplayer.copyLink') %></button>
            </div>
            <div class="flex gap-2">
              <button type="button" id="dmp-start-btn" hidden
                      class="px-4 py-1.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors"><%= t('games.durakMultiplayer.startGame') %></button>
              <button type="button" id="dmp-leave-btn"
                      class="px-4 py-1.5 rounded-lg bg-neutral-800 hover:bg-neutral-700 text-neutral-200 text-sm font-medium transition-colors"><%= t('games.durakMultiplayer.leaveRoom') %></button>
            </div>
          </div>
          <ul id="dmp-player-list" class="flex flex-wrap gap-2"></ul>
          <p id="dmp-waiting-hint" class="text-xs text-neutral-500 mt-2" hidden><%= t('games.durakMultiplayer.waitingForPlayers') %></p>
        </div>

        <%# Host-editable game rules - only meaningful (and only shown) while the
            room is still "lobby". Locked in at "starting"/"playing" (the toggle
            just hides along with dmp-start-btn/dmp-waiting-hint), so it never
            drifts from what the ready-checked game actually plays with. %>
        <div id="dmp-rules-panel" hidden class="rounded-xl border border-neutral-800 bg-neutral-900 p-4 mb-4">
          <p class="text-xs uppercase tracking-wide text-neutral-500 mb-2"><%= t('games.durakMultiplayer.rulesPanelTitle') %></p>
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="checkbox" id="dmp-rule-throwins" checked
                   class="mt-0.5 rounded border-neutral-700 bg-neutral-800 text-purple-600 focus:ring-purple-500 focus:ring-offset-neutral-900">
            <span>
              <span class="block text-sm text-neutral-200"><%= t('games.durakMultiplayer.ruleAllowThrowIns') %></span>
              <span class="block text-xs text-neutral-500"><%= t('games.durakMultiplayer.ruleAllowThrowInsDesc') %></span>
            </span>
          </label>
          <label class="flex items-start gap-2 cursor-pointer mt-3">
            <input type="checkbox" id="dmp-rule-transfers"
                   class="mt-0.5 rounded border-neutral-700 bg-neutral-800 text-purple-600 focus:ring-purple-500 focus:ring-offset-neutral-900">
            <span>
              <span class="block text-sm text-neutral-200"><%= t('games.durakMultiplayer.ruleAllowTransfers') %></span>
              <span class="block text-xs text-neutral-500"><%= t('games.durakMultiplayer.ruleAllowTransfersDesc') %></span>
            </span>
          </label>
          <p id="dmp-rules-host-hint" class="text-xs text-neutral-600 mt-2" hidden><%= t('games.durakMultiplayer.rulesHostOnlyHint') %></p>
        </div>

        <%# Ready check - shown only while room.status === "starting" (see
            durakRoomManager.js's handleStartGame()). Every seat, host included,
            must click Accept within the 45s window or get dropped from the room -
            the whole point is catching someone who's still connected but has
            mentally left the lobby before they get dragged into a live game. %>
        <div id="dmp-ready-check" hidden class="rounded-xl border border-purple-700/60 bg-neutral-900 p-6 mb-4 text-center">
          <p class="text-base font-semibold text-neutral-100 mb-1"><%= t('games.durakMultiplayer.readyCheckTitle') %></p>
          <p class="text-sm text-neutral-400 mb-4"><%= t('games.durakMultiplayer.readyCheckSubtitle') %></p>
          <p id="dmp-ready-countdown" class="text-2xl font-bold text-purple-400 tabular-nums mb-4"></p>
          <p id="dmp-ready-count" class="text-sm text-neutral-400 mb-4"></p>
          <button type="button" id="dmp-ready-accept-btn"
                  class="px-6 py-2.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors"><%= t('games.durakMultiplayer.readyCheckAccept') %></button>
          <p id="dmp-ready-waiting" hidden class="text-sm text-neutral-500 mt-3"><%= t('games.durakMultiplayer.readyCheckWaiting') %></p>
        </div>

        <div id="dmp-table-wrap" class="relative rounded-xl border border-neutral-800 bg-neutral-900 p-3 sm:p-4" hidden>
          <div id="dmp-board" class="relative rounded-lg bg-neutral-950 border border-neutral-800 min-h-[420px] flex flex-col">
            <div class="px-3 pt-3">
              <div id="dmp-opponents" class="flex flex-wrap justify-center gap-3"></div>
            </div>

            <div class="flex-1 flex items-center gap-3 px-3 py-2">
              <div class="flex flex-col items-center gap-1 shrink-0">
                <div id="dmp-deck" class="flex items-end gap-1 h-20"></div>
                <span id="dmp-deck-count" class="text-xs text-neutral-500 tabular-nums">0</span>
                <%# Stays visible even once the deck (and its rotated trump-card
                    reveal) runs out, so players don't lose track of trump. %>
                <span id="dmp-trump-label" class="text-xs font-medium"></span>
              </div>
              <div id="dmp-table-cards" class="flex-1 flex flex-wrap justify-center items-center gap-2 min-h-[100px]"></div>
            </div>

            <p id="dmp-status" class="text-center text-sm text-neutral-400 px-3 min-h-[1.5em]"></p>

            <div class="flex justify-center gap-3 py-2">
              <button type="button" id="dmp-take-btn" hidden
                      class="px-4 py-1.5 rounded-lg bg-rose-600 hover:bg-rose-500 text-white text-sm font-medium transition-colors"><%= t('games.durakMultiplayer.take') %></button>
              <button type="button" id="dmp-pass-btn" hidden
                      class="px-4 py-1.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors"><%= t('games.durakMultiplayer.pass') %></button>
            </div>

            <div class="px-3 pb-3">
              <div class="flex items-center justify-between mb-1.5">
                <p class="text-xs uppercase tracking-wide text-neutral-500"><%= t('games.durakMultiplayer.yourHand') %></p>
                <span id="dmp-my-clock" class="text-xs font-mono tabular-nums text-neutral-400"></span>
              </div>
              <div id="dmp-hand" class="flex flex-wrap justify-center gap-1 min-h-[88px]"></div>
            </div>
          </div>

          <div id="dmp-result-overlay" hidden
               class="absolute inset-3 sm:inset-4 rounded-lg bg-neutral-950/85 backdrop-blur-sm grid place-items-center text-center">
            <div class="px-4">
              <h2 id="dmp-result-title" class="text-xl font-semibold text-neutral-100 mb-2"></h2>
              <p id="dmp-result-detail" class="text-sm text-neutral-400 mb-2"></p>
              <ol id="dmp-result-standings" class="text-sm text-neutral-400 mb-4 space-y-0.5"></ol>
              <button type="button" id="dmp-result-back-btn"
                      class="px-5 py-2.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-400"><%= t('games.durakMultiplayer.backToLobby') %></button>
            </div>
          </div>

          <%# Shown only when a clicked card is legal BOTH as a defend and as a
              transfer at once - a trump matching the table's rank (see
              durakEngine.js's canTransfer() comment) - so the player picks
              which one they meant instead of the client silently guessing. %>
          <div id="dmp-action-choice" hidden
               class="absolute inset-3 sm:inset-4 rounded-lg bg-neutral-950/85 backdrop-blur-sm grid place-items-center text-center z-20">
            <div class="px-4">
              <p class="text-sm text-neutral-300 mb-4"><%= t('games.durakMultiplayer.chooseActionPrompt') %></p>
              <div class="flex gap-3 justify-center">
                <button type="button" id="dmp-choice-beat-btn"
                        class="px-4 py-2 rounded-lg bg-rose-600 hover:bg-rose-500 text-white text-sm font-medium transition-colors"><%= t('games.durakMultiplayer.beat') %></button>
                <button type="button" id="dmp-choice-transfer-btn"
                        class="px-4 py-2 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors"><%= t('games.durakMultiplayer.transfer') %></button>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </section>
</main>

