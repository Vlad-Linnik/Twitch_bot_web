<%- include('partials/head', { title: channel.channelLogin + ' ' + t('channelSettings.titleSuffix') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-3xl mx-auto px-6 py-16">
  <h1 class="text-3xl font-bold text-neutral-100 mb-1"><%= channel.channelLogin %> <%= t('channelSettings.titleSuffix') %></h1>
  <p class="text-neutral-500 text-sm mb-10"><%= t('channelSettings.subtitle') %></p>

  <% if (saved) { %>
    <div class="mb-8 rounded-md border border-green-800 bg-green-950/50 text-green-300 text-sm px-4 py-3">
      <%= t('channelSettings.saved') %>
    </div>
  <% } %>
  <% if (typeof error !== "undefined" && error) { %>
    <div class="mb-8 rounded-md border border-red-800 bg-red-950/50 text-red-300 text-sm px-4 py-3">
      <%= error %>
    </div>
  <% } %>

  <form method="post" action="/<%= channel.channelLogin %>/settings" data-transition="instant" id="settings-form" class="space-y-10">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <section class="grid sm:grid-cols-2 gap-4">
      <a href="/<%= channel.channelLogin %>/settings/banned-words" class="block rounded-lg border border-neutral-800 hover:border-neutral-700 bg-neutral-900/40 px-4 py-3 transition-colors">
        <h2 class="text-lg font-semibold text-neutral-100"><%= t('channelSettings.bannedWordsHeading') %></h2>
        <p class="text-neutral-500 text-sm mt-1"><%= config.bannedWords.words.length %> <%= t('channelSettings.wordCountSuffix') %></p>
      </a>
      <a href="/<%= channel.channelLogin %>/settings/spam-signatures" class="block rounded-lg border border-neutral-800 hover:border-neutral-700 bg-neutral-900/40 px-4 py-3 transition-colors">
        <h2 class="text-lg font-semibold text-neutral-100"><%= t('channelSettings.spamSignaturesHeading') %></h2>
        <p class="text-neutral-500 text-sm mt-1"><%= config.spamSignatures.length %> <%= t('channelSettings.wordCountSuffix') %></p>
      </a>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-neutral-100 mb-3"><%= t('channelSettings.sevenTvHeading') %></h2>
      <label class="block text-sm text-neutral-400 mb-1"><%= t('channelSettings.emoteSetUrlLabel') %></label>
      <input type="text" name="emoteSetUrl" value="<%= config.sevenTv.emoteSetUrl %>" class="w-full rounded-md bg-neutral-900 border border-neutral-800 px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-500" />
    </section>

    <section>
      <h2 class="text-lg font-semibold text-neutral-100 mb-3"><%= t('channelSettings.commandsHeading') %></h2>
      <div class="rounded-lg border border-neutral-800 overflow-hidden">
        <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-neutral-900 text-neutral-400">
            <tr>
              <th class="text-left font-medium px-4 py-2 whitespace-nowrap"><%= t('channelSettings.colCommand') %></th>
              <th class="text-left font-medium px-4 py-2"><%= t('channelSettings.colDescription') %></th>
              <th class="text-left font-medium px-4 py-2 whitespace-nowrap"><%= t('channelSettings.colSignature') %></th>
              <th class="text-left font-medium px-4 py-2 w-16"><%= t('channelSettings.colEnabled') %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800">
            <% Object.keys(config.commands).forEach(function(name) { %>
              <% const cmd = config.commands[name]; %>
              <tr class="odd:bg-neutral-950 even:bg-neutral-900/40">
                <td class="px-4 py-2 text-neutral-200 whitespace-nowrap align-top"><%= name %></td>
                <td class="px-4 py-2 text-neutral-400 align-top"><%= t('channelSettings.commandDesc.' + name) %></td>
                <td class="px-4 py-2 align-top">
                  <% if (cmd.signature !== undefined) { %>
                    <div class="flex items-center w-32 rounded-md bg-neutral-900 border border-neutral-800 px-2 py-1 focus-within:border-purple-500">
                      <span class="text-sm font-mono text-neutral-500 select-none">!</span>
                      <input type="text" name="commands.<%= name %>.signature" value="<%= cmd.signature.replace(/^!/, '') %>" class="w-full bg-transparent text-sm font-mono text-purple-300 focus:outline-none" />
                    </div>
                  <% } else { %>
                    <span class="text-neutral-600">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 align-top">
                  <label class="toggle-switch">
                    <input type="checkbox" name="commands.<%= name %>.enabled" <%= cmd.enabled ? 'checked' : '' %> class="sr-only" />
                    <span class="toggle-track"><span class="toggle-thumb"></span></span>
                  </label>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-neutral-100 mb-1"><%= t('channelSettings.responsesHeading') %></h2>
      <p class="text-neutral-500 text-sm mb-3"><%= t('channelSettings.responsesIntro') %></p>

      <label class="block text-sm text-neutral-400 mb-1"><%= t('channelSettings.busyResponsesLabel') %></label>
      <p class="text-neutral-600 text-xs mb-1"><%= t('channelSettings.busyResponsesHint') %></p>
      <textarea name="busyResponses" rows="3" class="w-full rounded-md bg-neutral-900 border border-neutral-800 px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-500"><%= config.responses.busy.join('\n') %></textarea>

      <label class="block text-sm text-neutral-400 mt-3 mb-1"><%= t('channelSettings.yesNoResponsesLabel') %></label>
      <p class="text-neutral-600 text-xs mb-1"><%= t('channelSettings.yesNoResponsesHint') %></p>
      <textarea name="yesNoResponses" rows="3" class="w-full rounded-md bg-neutral-900 border border-neutral-800 px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-500"><%= config.responses.yesNo.join('\n') %></textarea>

      <label class="block text-sm text-neutral-400 mt-3 mb-1"><%= t('channelSettings.insultModExemptLabel') %></label>
      <p class="text-neutral-600 text-xs mb-1"><%= t('channelSettings.insultModExemptHint') %></p>
      <textarea name="insultModExempt" rows="2" class="w-full rounded-md bg-neutral-900 border border-neutral-800 px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-500"><%= config.responses.insultModExempt.join('\n') %></textarea>

      <label class="block text-sm text-neutral-400 mt-3 mb-1"><%= t('channelSettings.insufficientPermissionsLabel') %></label>
      <p class="text-neutral-600 text-xs mb-1"><%= t('channelSettings.insufficientPermissionsHint') %></p>
      <input type="text" name="insufficientPermissions" value="<%= config.responses.insufficientPermissions %>" class="w-full rounded-md bg-neutral-900 border border-neutral-800 px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-500" />
    </section>

    <div class="sticky bottom-6 flex justify-center pointer-events-none">
      <button type="submit" id="save-button" class="pointer-events-auto px-5 py-2.5 rounded-md bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium shadow-lg shadow-black/40 transition-colors">
        <%= t('channelSettings.save') %>
      </button>
    </div>
  </form>
</main>

<dialog id="unsaved-changes-dialog" class="rounded-lg border border-neutral-800 bg-neutral-900 text-neutral-200 p-6 m-auto backdrop:bg-black/60">
  <p class="text-sm mb-5"><%= t('channelSettings.unsavedChangesWarning') %></p>
  <div class="flex justify-end gap-3 text-sm">
    <button type="button" command="close" commandfor="unsaved-changes-dialog" class="px-3 py-1.5 rounded-md text-neutral-400 hover:text-neutral-100 transition-colors"><%= t('channelSettings.unsavedChangesStay') %></button>
    <button type="button" id="unsaved-changes-leave" class="px-3 py-1.5 rounded-md bg-purple-600 hover:bg-purple-500 text-white transition-colors"><%= t('channelSettings.unsavedChangesLeave') %></button>
  </div>
</dialog>

<script src="/js/settings-form.js" defer></script>
<%- include('partials/foot') %>
