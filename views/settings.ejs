<%- include('partials/head', { title: channel.channelLogin + ' ' + t('channelSettings.titleSuffix') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-3xl mx-auto px-6 py-16">
  <h1 class="text-3xl font-bold text-neutral-100 mb-1"><%= channel.channelLogin %> <%= t('channelSettings.titleSuffix') %></h1>
  <p class="text-neutral-500 text-sm mb-10"><%= t('channelSettings.subtitle') %></p>

  <% if (saved) { %>
    <div class="mb-8 rounded-md border border-green-800 bg-green-950/50 text-green-300 text-sm px-4 py-3">
      <%= t('channelSettings.saved') %>
    </div>
  <% } %>
  <% if (typeof error !== "undefined" && error) { %>
    <div class="mb-8 rounded-md border border-red-800 bg-red-950/50 text-red-300 text-sm px-4 py-3">
      <%= error %>
    </div>
  <% } %>

  <%
    // The bot's command map, grouped into human sections. Anything in config.commands not
    // claimed here (a future bot command) lands in the trailing "other" group instead of
    // silently disappearing from the form. question/directmsg/insult/customCommandTimer/
    // counterUpdate are deliberately NOT in these tables - they aren't chat commands, and
    // each is rendered next to the setting it actually belongs to (insult lives on the
    // Banned Words page). The custom-commands and counters command groups moved to their
    // own sub-pages (channelCustomCommandsSettings / channelCountersSettings), linked from
    // the cards below - their names stay claimed so they don't resurface under "other".
    const groups = [
      { key: 'chatStats', names: ['topchatters', 'topsmiles', 'countword', 'countmsg', 'countunique', 'update7tv', 'botinfo', 'randomclip'] },
      { key: 'miniGames', names: ['muteduel'] },
    ];
    const placedElsewhere = new Set([
      'question', 'directmsg', 'insult', 'customCommandTimer', 'counterUpdate',
      'addcommand', 'settimer', 'setpin', 'setannounce', 'delcommand',
      'addcounter', 'delcounter', 'exception',
    ]);
    const claimed = new Set(placedElsewhere);
    groups.forEach(g => g.names.forEach(n => claimed.add(n)));
    const other = Object.keys(config.commands).filter(n => !claimed.has(n));
    if (other.length) groups.push({ key: 'other', names: other });

    function commandTable(names) { return names.filter(n => config.commands[n]); }
  %>

  <form method="post" action="/<%= channel.channelLogin %>/settings" data-transition="instant" data-autosave id="settings-form" class="space-y-12">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <section class="mb-4">
      <a href="/<%= channel.channelLogin %>/settings/custom-commands" class="flex items-center gap-3 rounded-lg border border-purple-700/60 hover:border-purple-500 bg-purple-950/30 hover:bg-purple-950/50 px-5 py-4 transition-colors">
        <span class="text-2xl leading-none">🛠️</span>
        <span>
          <span class="block text-lg font-semibold text-neutral-100"><%= t('channelSettings.group.customCommands') %></span>
          <span class="block text-neutral-400 text-sm mt-0.5"><%= customCommandCount %> <%= t('channelSettings.commandCountSuffix') %></span>
        </span>
      </a>
    </section>

    <section class="grid sm:grid-cols-2 gap-4">
      <a href="/<%= channel.channelLogin %>/settings/spam-signatures" class="flex items-center gap-3 rounded-lg border border-neutral-800 hover:border-neutral-700 bg-neutral-900/40 px-4 py-3 transition-colors">
        <span class="text-xl leading-none">🚨</span>
        <span>
          <span class="block text-lg font-semibold text-neutral-100"><%= t('channelSettings.spamSignaturesHeading') %></span>
          <span class="block text-neutral-500 text-sm mt-1"><%= config.spamSignatures.length %> <%= t('channelSettings.wordCountSuffix') %></span>
        </span>
      </a>
      <a href="/<%= channel.channelLogin %>/settings/counters" class="flex items-center gap-3 rounded-lg border border-neutral-800 hover:border-neutral-700 bg-neutral-900/40 px-4 py-3 transition-colors">
        <span class="text-xl leading-none">🔢</span>
        <span>
          <span class="block text-lg font-semibold text-neutral-100"><%= t('channelSettings.group.counters') %></span>
          <span class="block text-neutral-500 text-sm mt-1"><%= counterCount %> <%= t('channelSettings.counterCountSuffix') %></span>
        </span>
      </a>
      <a href="/<%= channel.channelLogin %>/settings/change-log" class="flex items-center gap-3 rounded-lg border border-neutral-800 hover:border-neutral-700 bg-neutral-900/40 px-4 py-3 transition-colors">
        <span class="text-xl leading-none">📜</span>
        <span>
          <span class="block text-lg font-semibold text-neutral-100"><%= t('channelSettings.changeLogHeading') %></span>
          <span class="block text-neutral-500 text-sm mt-1"><%= t('channelSettings.changeLogIntro') %></span>
        </span>
      </a>
      <% if (canManageModerators) { %>
        <a href="/<%= channel.channelLogin %>/settings/moderators" class="flex items-center gap-3 rounded-lg border border-neutral-800 hover:border-neutral-700 bg-neutral-900/40 px-4 py-3 transition-colors">
          <span class="text-xl leading-none">🛡️</span>
          <span>
            <span class="block text-lg font-semibold text-neutral-100"><%= t('channelSettings.moderatorsHeading') %></span>
            <span class="block text-neutral-500 text-sm mt-1"><%= t('channelSettings.moderatorsIntro') %></span>
          </span>
        </a>
      <% } %>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-neutral-100 mb-3">🟣 <%= t('channelSettings.sevenTvHeading') %></h2>
      <% if (sevenTvStatus.linked) { %>
        <p class="text-sm text-green-400">✅ <%= t('channelSettings.sevenTvLinked') %> (<%= sevenTvStatus.emoteCount %>)</p>
      <% } else { %>
        <p class="text-sm text-neutral-500">⚠️ <%= t('channelSettings.sevenTvNotLinked') %></p>
      <% } %>
    </section>

    <% groups.forEach(function(group) { %>
      <% const names = commandTable(group.names); if (names.length === 0) return; %>
      <section>
        <h2 class="text-lg font-semibold text-neutral-100 mb-1"><%= t('channelSettings.group.' + group.key) %></h2>
        <p class="text-neutral-500 text-sm mb-3"><%= t('channelSettings.groupIntro.' + group.key) %></p>
        <%- include('partials/commandTable', { names, config }) %>
      </section>
    <% }) %>

    <%- include('partials/autosaveStatus') %>
  </form>

  <!-- Automatic bot behavior: things the bot does on its own, no chat command involved - banned-
       word timeouts, yes/no answers, and mention replies. Merged into one place (each individually
       toggleable) instead of being split across a separate Banned Words page and this page's
       bottom section, since a bare "N words configured" tile gave no hint the feature could be off. -->
  <section class="mt-12">
    <h2 class="text-lg font-semibold text-neutral-100 mb-1">🤖 <%= t('channelSettings.autoBehaviorHeading') %></h2>
    <p class="text-neutral-500 text-sm mb-4"><%= t('channelSettings.autoBehaviorIntro') %></p>

    <div class="rounded-lg border border-neutral-800 bg-neutral-900/40 divide-y divide-neutral-800">
      <!-- Banned words: its own dedicated toggle form (same route the old Banned Words page
           used), since it isn't a `commands.*` entry parseSubmittedConfig understands. -->
      <div class="px-4 py-3">
        <form method="post" action="/<%= channel.channelLogin %>/settings/banned-words/detection-toggle" data-transition="instant" data-autosave>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="flex items-center justify-between gap-4">
            <div class="min-w-0">
              <span class="text-sm font-medium text-neutral-200">🚫 <%= t('channelSettings.bannedWordsHeading') %></span>
              <p class="text-neutral-600 text-xs mt-0.5"><%= t('channelSettings.detectionToggleHint') %></p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <span data-autosave-status aria-live="polite"
                    data-saving-text="<%= t('channelSettings.autosaveSaving') %>"
                    data-saved-text="<%= t('channelSettings.autosaveSaved') %>"
                    data-error-text="<%= t('channelSettings.autosaveError') %>"
                    class="autosave-status px-2 py-1 rounded-md text-xs font-medium"></span>
              <label class="toggle-switch">
                <input type="checkbox" name="detectionEnabled" <%= config.commands.insult && config.commands.insult.enabled ? 'checked' : '' %> class="sr-only" />
                <span class="toggle-track"><span class="toggle-thumb"></span></span>
              </label>
              <button type="submit" class="save-fab px-3 py-1.5 rounded-md bg-purple-600 hover:bg-purple-500 text-white text-xs font-medium transition-colors"><%= t('channelSettings.save') %></button>
            </div>
          </div>
          <a href="/<%= channel.channelLogin %>/settings/banned-words" class="inline-block mt-2 text-xs text-purple-400 hover:text-purple-300"><%= config.bannedWords.words.length %> <%= t('channelSettings.wordCountSuffix') %> →</a>
        </form>
      </div>

      <!-- Yes/No answers + mention replies: both are commands.* fields, so they share one
           autosave form posting to the main settings endpoint (parseSubmittedConfig only ever
           touches the fields actually present in a submission - see lib/settingsValidation.js -
           so this form coexisting with the one above is safe). -->
      <form method="post" action="/<%= channel.channelLogin %>/settings" data-transition="instant" data-autosave>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <% if (config.commands.question) { %>
          <div class="px-4 py-3">
            <div class="flex items-center justify-between gap-4 mb-1">
              <span class="text-sm font-medium text-neutral-200">❓ <%= t('channelSettings.commandName.question') %></span>
              <div class="flex items-center gap-4">
                <label class="flex items-center gap-1.5 text-xs text-neutral-500">
                  <%= t('channelSettings.colCooldown') %>
                  <input type="number" min="0" max="86400" step="1" name="commands.question.cooldownSeconds"
                         value="<%= Math.round(config.commands.question.cooldownMs / 1000) %>"
                         class="w-20 rounded-md bg-neutral-900 border border-neutral-800 px-2 py-1 text-sm text-neutral-200 tabular-nums focus:outline-none focus:border-purple-500" />
                </label>
                <input type="hidden" name="commands.question.present" value="1" />
                <label class="toggle-switch">
                  <input type="checkbox" name="commands.question.enabled" <%= config.commands.question.enabled ? 'checked' : '' %> class="sr-only" />
                  <span class="toggle-track"><span class="toggle-thumb"></span></span>
                </label>
              </div>
            </div>
            <p class="text-neutral-600 text-xs mb-3"><%= t('channelSettings.commandDesc.question') %></p>
            <label class="block text-sm text-neutral-400 mb-1"><%= t('channelSettings.yesNoResponsesLabel') %></label>
            <p class="text-neutral-600 text-xs mb-1"><%= t('channelSettings.yesNoResponsesHint') %></p>
            <textarea name="yesNoResponses" rows="3" class="w-full rounded-md bg-neutral-900 border border-neutral-800 px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-500"><%= config.responses.yesNo.join('\n') %></textarea>
          </div>
        <% } %>

        <% if (config.commands.directmsg) { %>
          <div class="px-4 py-3">
            <div class="flex items-center justify-between gap-4 mb-1">
              <span class="text-sm font-medium text-neutral-200">💬 <%= t('channelSettings.commandName.directmsg') %></span>
              <div class="flex items-center gap-4">
                <label class="flex items-center gap-1.5 text-xs text-neutral-500">
                  <%= t('channelSettings.colCooldown') %>
                  <input type="number" min="0" max="86400" step="1" name="commands.directmsg.cooldownSeconds"
                         value="<%= Math.round(config.commands.directmsg.cooldownMs / 1000) %>"
                         class="w-20 rounded-md bg-neutral-900 border border-neutral-800 px-2 py-1 text-sm text-neutral-200 tabular-nums focus:outline-none focus:border-purple-500" />
                </label>
                <input type="hidden" name="commands.directmsg.present" value="1" />
                <label class="toggle-switch">
                  <input type="checkbox" name="commands.directmsg.enabled" <%= config.commands.directmsg.enabled ? 'checked' : '' %> class="sr-only" />
                  <span class="toggle-track"><span class="toggle-thumb"></span></span>
                </label>
              </div>
            </div>
            <p class="text-neutral-600 text-xs mb-3"><%= t('channelSettings.commandDesc.directmsg') %></p>
            <label class="block text-sm text-neutral-400 mb-1"><%= t('channelSettings.busyResponsesLabel') %></label>
            <p class="text-neutral-600 text-xs mb-1"><%= t('channelSettings.busyResponsesHint') %></p>
            <textarea name="busyResponses" rows="3" class="w-full rounded-md bg-neutral-900 border border-neutral-800 px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-500"><%= config.responses.busy.join('\n') %></textarea>
          </div>
        <% } %>

        <div class="px-4 py-3 flex items-center justify-end gap-3">
          <span data-autosave-status aria-live="polite"
                data-saving-text="<%= t('channelSettings.autosaveSaving') %>"
                data-saved-text="<%= t('channelSettings.autosaveSaved') %>"
                data-error-text="<%= t('channelSettings.autosaveError') %>"
                class="autosave-status px-2 py-1 rounded-md text-xs font-medium"></span>
          <button type="submit" class="save-fab px-3 py-1.5 rounded-md bg-purple-600 hover:bg-purple-500 text-white text-xs font-medium transition-colors"><%= t('channelSettings.save') %></button>
        </div>
      </form>
    </div>
  </section>
</main>

<script src="/js/autosave.js" defer></script>
<%- include('partials/foot') %>
