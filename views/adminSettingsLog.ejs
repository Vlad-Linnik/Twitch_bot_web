<%- include('partials/head', { title: t('admin.title') + ' · ' + t('admin.tabSettingsLog') }) %>
<%- include('partials/nav') %>

<%
  // Raw before/after only shown behind the collapsed "Raw data" toggle - entries[i].description
  // (lib/settingsChangeDescribe.js) is the primary summary now.
  function fmt(value) {
    if (value === null || value === undefined) return '—';
    const text = typeof value === 'object' ? JSON.stringify(value) : String(value);
    return text.length > 300 ? text.slice(0, 300) + '…' : text;
  }
%>

<main class="pt-14 max-w-6xl mx-auto px-6 py-16">
  <h1 class="text-3xl font-bold text-neutral-100 mb-1"><%= t('admin.title') %></h1>
  <p class="text-neutral-500 text-sm mb-8"><%= t('admin.settingsLogIntro') %></p>

  <%- include('partials/adminTabs', { tab }) %>

  <% if (flash) { %>
    <div class="mb-8 rounded-md border border-green-800 bg-green-950/50 text-green-300 text-sm px-4 py-3">
      <%= t('admin.flash.' + flash) %>
    </div>
  <% } %>

  <% if (entries.length > 0) { %>
    <form method="post" action="/admin/settings-log/delete-all" data-transition="instant"
          data-confirm-delete="<%= t('settingsChangeLog.deleteAllConfirm') %>" class="flex justify-end mb-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="px-3 py-1.5 rounded-md border border-red-900 text-red-400 hover:bg-red-500/10 text-xs font-medium transition-colors">
        <%= t('settingsChangeLog.deleteAllButton') %>
      </button>
    </form>
  <% } %>

  <div class="rounded-lg border border-neutral-800 overflow-hidden">
    <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-neutral-900 text-neutral-400">
        <tr>
          <th class="text-left font-medium px-4 py-2 whitespace-nowrap"><%= t('settingsChangeLog.colWhen') %></th>
          <th class="text-left font-medium px-4 py-2"><%= t('admin.colChannel') %></th>
          <th class="text-left font-medium px-4 py-2"><%= t('settingsChangeLog.colModerator') %></th>
          <th class="text-left font-medium px-4 py-2"><%= t('settingsChangeLog.colCategory') %></th>
          <th class="text-left font-medium px-4 py-2"><%= t('settingsChangeLog.colAction') %></th>
          <th class="text-left font-medium px-4 py-2"><%= t('settingsChangeLog.colTarget') %></th>
          <th class="text-left font-medium px-4 py-2"><%= t('settingsChangeLog.colChanges') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-neutral-800">
        <% entries.forEach(function(e) { %>
          <tr class="odd:bg-neutral-950 even:bg-neutral-900/40">
            <td class="px-4 py-2 text-neutral-500 whitespace-nowrap"><%= new Date(e.timestamp).toLocaleString(locale === 'ru' ? 'ru-RU' : 'en-US') %></td>
            <td class="px-4 py-2">
              <a href="/<%= e.channelLogin %>/settings/change-log" class="text-purple-400 hover:text-purple-300"><%= e.channelLogin %></a>
            </td>
            <td class="px-4 py-2 text-neutral-200"><%= e.moderatorDisplayName || e.moderatorLogin || e.moderatorId %></td>
            <td class="px-4 py-2 text-neutral-400"><%= t('settingsChangeLog.category.' + e.category) %></td>
            <td class="px-4 py-2 text-neutral-400"><%= t('settingsChangeLog.action.' + e.action) %></td>
            <td class="px-4 py-2 text-neutral-300 font-mono text-xs break-all"><%= e.target %></td>
            <td class="px-4 py-2 text-neutral-200 text-xs max-w-sm">
              <%= e.description %>
              <details class="mt-1 text-neutral-600">
                <summary class="cursor-pointer select-none hover:text-neutral-400"><%= t('settingsChangeLog.rawDetails') %></summary>
                <div class="mt-1 space-y-0.5 break-all">
                  <div><%= t('settingsChangeLog.colBefore') %>: <%= fmt(e.before) %></div>
                  <div><%= t('settingsChangeLog.colAfter') %>: <%= fmt(e.after) %></div>
                </div>
              </details>
            </td>
          </tr>
        <% }) %>
        <% if (entries.length === 0) { %>
          <tr><td colspan="7" class="px-4 py-6 text-center text-neutral-500"><%= t('settingsChangeLog.empty') %></td></tr>
        <% } %>
      </tbody>
    </table>
    </div>
  </div>
  <script src="/js/confirm-delete.js" defer></script>

  <% if (totalPages > 1) { %>
    <nav class="flex items-center justify-center gap-3 mt-4 text-xs">
      <% if (page > 1) { %>
        <a href="?page=<%= page - 1 %>" class="px-3 py-1.5 rounded-md border border-neutral-800 text-neutral-300 hover:border-purple-600 hover:text-neutral-100 transition-colors"><%= t('statistics.pagePrev') %></a>
      <% } else { %>
        <span class="px-3 py-1.5 rounded-md border border-neutral-900 text-neutral-700 select-none"><%= t('statistics.pagePrev') %></span>
      <% } %>
      <span class="text-neutral-500 tabular-nums"><%= t('statistics.pageLabel') %> <%= page %> / <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a href="?page=<%= page + 1 %>" class="px-3 py-1.5 rounded-md border border-neutral-800 text-neutral-300 hover:border-purple-600 hover:text-neutral-100 transition-colors"><%= t('statistics.pageNext') %></a>
      <% } else { %>
        <span class="px-3 py-1.5 rounded-md border border-neutral-900 text-neutral-700 select-none"><%= t('statistics.pageNext') %></span>
      <% } %>
    </nav>
  <% } %>
</main>

<%- include('partials/foot') %>
