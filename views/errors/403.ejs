<%- include('../partials/head', { title: t('errors.accessDeniedTitle') }) %>
<%- include('../partials/nav') %>

<main class="pt-14 max-w-lg mx-auto px-6 py-24 text-center">
  <h1 class="text-2xl font-bold text-neutral-100 mb-3"><%= t('errors.accessDeniedTitle') %></h1>
  <p class="text-neutral-400">
    <% if (typeof user !== "undefined" && user) { %>
      <%= t('errors.accessDeniedMessage') %>
    <% } else { %>
      <%= t('errors.loginRequiredMessage') %> <a href="/auth/login" class="text-purple-400 hover:text-purple-300"><%= t('errors.loginRequiredLink') %></a><%= t('errors.loginRequiredSuffix') %>
    <% } %>
  </p>
  <% if (typeof message !== "undefined" && message) { %>
    <p class="text-neutral-500 text-sm mt-4"><%= message %></p>
  <% } %>
</main>

<%- include('../partials/foot') %>
