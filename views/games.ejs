<%- include('partials/head', { title: t('games.title') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-3xl mx-auto px-6 py-12">
  <h1 class="text-3xl font-bold text-neutral-100 mb-8"><%= t('games.title') %></h1>

  <div class="grid gap-4 sm:grid-cols-2">
    <a href="/games/falling-blocks"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, a half-built stack of blocks. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <g>
            <rect x="66" y="6" width="16" height="16" rx="2" fill="#c084fc"/>
            <rect x="66" y="24" width="16" height="16" rx="2" fill="#c084fc"/>
            <rect x="84" y="24" width="16" height="16" rx="2" fill="#c084fc"/>
            <rect x="84" y="6" width="16" height="16" rx="2" fill="#c084fc" opacity="0.35"/>
          </g>
          <rect x="12" y="68" width="16" height="16" rx="2" fill="#38bdf8"/>
          <rect x="30" y="68" width="16" height="16" rx="2" fill="#38bdf8"/>
          <rect x="30" y="50" width="16" height="16" rx="2" fill="#38bdf8"/>
          <rect x="48" y="68" width="16" height="16" rx="2" fill="#fbbf24"/>
          <rect x="66" y="68" width="16" height="16" rx="2" fill="#fbbf24"/>
          <rect x="66" y="50" width="16" height="16" rx="2" fill="#34d399"/>
          <rect x="84" y="68" width="16" height="16" rx="2" fill="#fb7185"/>
          <rect x="102" y="68" width="16" height="16" rx="2" fill="#fb7185"/>
          <rect x="102" y="50" width="16" height="16" rx="2" fill="#818cf8"/>
          <rect x="120" y="68" width="16" height="16" rx="2" fill="#fb923c"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.fallingBlocks.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.fallingBlocks.cardDescription') %></p>
    </a>

    <a href="/games/pipe-dodger"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, a bird weaving between two pipes. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <rect x="30" y="0" width="18" height="30" rx="2" fill="#38bdf8"/>
          <rect x="26" y="26" width="26" height="8" rx="2" fill="#0f7ea8"/>
          <rect x="30" y="60" width="18" height="30" rx="2" fill="#38bdf8"/>
          <rect x="26" y="56" width="26" height="8" rx="2" fill="#0f7ea8"/>
          <rect x="102" y="0" width="18" height="16" rx="2" fill="#38bdf8"/>
          <rect x="98" y="12" width="26" height="8" rx="2" fill="#0f7ea8"/>
          <rect x="102" y="48" width="18" height="42" rx="2" fill="#38bdf8"/>
          <rect x="98" y="44" width="26" height="8" rx="2" fill="#0f7ea8"/>
          <g transform="translate(75,44) rotate(-12)">
            <rect x="-11" y="-9" width="22" height="18" rx="6" fill="#38bdf8"/>
            <circle cx="4" cy="-2" r="1.6" fill="#0b0b0b"/>
          </g>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.pipeDodger.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.pipeDodger.cardDescription') %></p>
    </a>

    <a href="/games/2048"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, a few merged tiles on a grid. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <rect x="35" y="5" width="80" height="80" rx="4" fill="#262626"/>
          <rect x="41" y="11" width="32" height="32" rx="3" fill="#e5e5e5"/>
          <rect x="77" y="11" width="32" height="32" rx="3" fill="#38bdf8"/>
          <rect x="41" y="47" width="32" height="32" rx="3" fill="#a855f7"/>
          <rect x="77" y="47" width="32" height="32" rx="3" fill="#fbbf24"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.2048.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.2048.cardDescription') %></p>
    </a>

    <%# Durak: one card for both modes now - /games/durak itself is a mode-select
        page (vs computer, open to everyone; with people, login-gated inline
        rather than by hiding this card - see routes/games.js and
        views/gameDurak.ejs). %>
    <a href="/games/durak"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, two fanned playing cards with a trump suit peeking out. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <g transform="translate(75,48) rotate(-14)">
            <rect x="-19" y="-27" width="38" height="54" rx="4" fill="#e5e5e5" stroke="#171717" stroke-width="1"/>
            <text x="-13" y="-14" font-size="12" font-family="sans-serif" fill="#dc2626">K</text>
            <text x="-13" y="-2" font-size="12" font-family="sans-serif" fill="#dc2626">♥</text>
          </g>
          <g transform="translate(75,48) rotate(14)">
            <rect x="-19" y="-27" width="38" height="54" rx="4" fill="#fafafa" stroke="#171717" stroke-width="1"/>
            <text x="7" y="20" font-size="12" font-family="sans-serif" fill="#171717" transform="rotate(180)">A</text>
            <text x="7" y="8" font-size="12" font-family="sans-serif" fill="#171717" transform="rotate(180)">♠</text>
          </g>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.durak.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.durak.cardDescription') %></p>
    </a>

    <a href="/games/minesweeper"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, a partly-cleared minesweeper grid. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <g fill="#404040">
            <rect x="35" y="5" width="20" height="20"/>
            <rect x="57" y="5" width="20" height="20"/>
            <rect x="35" y="27" width="20" height="20"/>
            <rect x="35" y="49" width="20" height="20"/>
          </g>
          <g fill="#171717">
            <rect x="79" y="5" width="20" height="20"/>
            <rect x="101" y="5" width="20" height="20"/>
            <rect x="57" y="27" width="20" height="20"/>
            <rect x="79" y="27" width="20" height="20"/>
            <rect x="101" y="27" width="20" height="20"/>
            <rect x="57" y="49" width="20" height="20"/>
            <rect x="79" y="49" width="20" height="20"/>
            <rect x="101" y="49" width="20" height="20"/>
          </g>
          <text x="63" y="42" font-size="14" font-weight="700" font-family="sans-serif" fill="#38bdf8">1</text>
          <text x="85" y="42" font-size="14" font-weight="700" font-family="sans-serif" fill="#34d399">2</text>
          <text x="63" y="64" font-size="14" font-weight="700" font-family="sans-serif" fill="#38bdf8">1</text>
          <circle cx="111" cy="59" r="6" fill="#fb7185"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.minesweeper.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.minesweeper.cardDescription') %></p>
    </a>

    <a href="/games/match-3"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, a few colorful crystals mid-match. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <rect x="35" y="30" width="18" height="18" rx="4" fill="#fb7185"/>
          <rect x="55" y="30" width="18" height="18" rx="4" fill="#fb7185"/>
          <rect x="75" y="30" width="18" height="18" rx="4" fill="#fb7185"/>
          <rect x="95" y="10" width="18" height="18" rx="4" fill="#38bdf8"/>
          <rect x="95" y="30" width="18" height="18" rx="4" fill="#fbbf24"/>
          <rect x="95" y="50" width="18" height="18" rx="4" fill="#34d399"/>
          <rect x="35" y="52" width="18" height="18" rx="4" fill="#a855f7"/>
          <rect x="55" y="10" width="18" height="18" rx="4" fill="#34d399"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.match3.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.match3.cardDescription') %></p>
    </a>

    <a href="/games/battleship"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, a grid with a few hit/miss markers and a ship silhouette. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <rect x="20" y="10" width="110" height="70" fill="none" stroke="#404040" stroke-width="1"/>
          <rect x="42" y="32" width="66" height="16" rx="3" fill="#38bdf8" opacity="0.5"/>
          <circle cx="53" cy="21" r="5" fill="none" stroke="#a3a3a3" stroke-width="2"/>
          <circle cx="53" cy="21" r="1.5" fill="#a3a3a3"/>
          <rect x="86" y="54" width="11" height="11" fill="#fb7185"/>
          <rect x="97" y="54" width="11" height="11" fill="#be123c"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.battleship.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.battleship.cardDescription') %></p>
    </a>

    <a href="/games/pong"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, two paddles and a ball mid-court. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <line x1="75" y1="6" x2="75" y2="84" stroke="#404040" stroke-width="3" stroke-dasharray="6 6"/>
          <rect x="16" y="30" width="7" height="26" rx="2" fill="#c084fc"/>
          <rect x="127" y="40" width="7" height="26" rx="2" fill="#e5e5e5"/>
          <circle cx="90" cy="45" r="5" fill="#38bdf8"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.pong.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.pong.cardDescription') %></p>
    </a>

    <a href="/games/connect-four"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, a Connect Four board with 4 discs in a row. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <rect x="20" y="10" width="110" height="70" rx="6" fill="#0c4a6e"/>
          <circle cx="35" cy="60" r="10" fill="#c084fc"/>
          <circle cx="57" cy="60" r="10" fill="#c084fc"/>
          <circle cx="79" cy="60" r="10" fill="#c084fc"/>
          <circle cx="101" cy="60" r="10" fill="#c084fc"/>
          <circle cx="35" cy="38" r="10" fill="#171717"/>
          <circle cx="101" cy="38" r="10" fill="#fbbf24"/>
          <circle cx="79" cy="38" r="10" fill="#171717"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.connectFour.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.connectFour.cardDescription') %></p>
    </a>

    <a href="/games/backgammon"
       class="group block rounded-xl border border-neutral-800 bg-neutral-900 p-5 hover:border-purple-500/50 transition-colors">
      <%# Decorative preview - original inline SVG, a few backgammon points with checker stacks and a die. %>
      <div class="mb-4 h-28 rounded-lg bg-neutral-950 border border-neutral-800 grid place-items-center overflow-hidden">
        <svg width="150" height="90" viewBox="0 0 150 90" aria-hidden="true">
          <rect x="10" y="10" width="130" height="70" rx="4" fill="#022c22"/>
          <polygon points="20,80 35,80 27.5,35" fill="#c084fc"/>
          <polygon points="40,80 55,80 47.5,35" fill="#171717"/>
          <polygon points="95,10 110,10 102.5,55" fill="#171717"/>
          <polygon points="115,10 130,10 122.5,55" fill="#fbbf24"/>
          <circle cx="27.5" cy="70" r="8" fill="#a855f7"/>
          <circle cx="27.5" cy="54" r="8" fill="#a855f7"/>
          <rect x="66" y="36" width="18" height="18" rx="3" fill="#e5e5e5"/>
          <text x="71" y="50" font-size="14" font-weight="700" font-family="sans-serif" fill="#171717">4</text>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-neutral-100 group-hover:text-purple-300 transition-colors"><%= t('games.backgammon.name') %></h2>
      <p class="text-sm text-neutral-500 mt-1"><%= t('games.backgammon.cardDescription') %></p>
    </a>
  </div>
</main>

<%- include('partials/foot') %>
