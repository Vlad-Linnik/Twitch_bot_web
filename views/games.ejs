<%- include('partials/head', { title: t('games.title') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-3xl mx-auto px-6 py-12">
  <h1 class="text-3xl font-bold text-neutral-100 mb-8"><%= t('games.title') %></h1>

  <%
    // Category names are per-locale (db/gameCatalogRepo.js's `names` map) -
    // fall back to English, then whatever locale is present, so a category
    // never renders blank if it's missing a translation.
    function categoryName(category) {
      if (!category || !category.names) return '';
      return category.names[locale] || category.names.en || Object.values(category.names).find(Boolean) || '';
    }
  %>
  <% groups.forEach(function(group, i) { %>
    <div class="<%= i === 0 ? '' : 'mt-10' %>">
      <% if (group.category) { %>
        <h2 class="text-xl font-semibold text-neutral-200 mb-4"><%= categoryName(group.category) %></h2>
      <% } %>
      <div class="grid gap-4 sm:grid-cols-2">
        <% group.games.forEach(function(game) { %>
          <%- include('partials/gameCard', { game }) %>
        <% }) %>
      </div>
    </div>
  <% }) %>
</main>

<%- include('partials/foot') %>
