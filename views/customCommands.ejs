<%- include('partials/head', { title: channel.channelLogin + ' · ' + t('customCommands.title') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-4xl mx-auto px-6 py-12">

  <header class="mb-8">
    <h1 class="text-3xl font-bold text-neutral-100 mb-1"><%= t('customCommands.title') %></h1>
    <p class="text-sm text-neutral-500"><%= channel.channelLogin %> · <%= t('customCommands.subtitle') %></p>
  </header>

  <% if (saved) { %>
    <p class="mb-6 rounded-lg border border-green-800/50 bg-green-900/20 text-green-400 px-4 py-2.5 text-sm">
      <%= saved === 'deleted' ? t('customCommands.deleted') : t('customCommands.saved') %>
    </p>
  <% } %>
  <% if (error) { %>
    <p class="mb-6 rounded-lg border border-red-800/50 bg-red-900/20 text-red-400 px-4 py-2.5 text-sm">
      <%= t('customCommands.errors.' + error) %>
    </p>
  <% } %>

  <!-- Create / edit -->
  <section class="mb-10 rounded-lg border border-neutral-800 bg-neutral-900 p-6">
    <h2 class="text-lg font-semibold text-neutral-100 mb-4" id="form-heading"><%= t('customCommands.create') %></h2>

    <form method="post" action="/<%= channel.channelLogin %>/settings/custom-commands/commands" class="space-y-4" id="command-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_10rem] gap-4">
        <div>
          <label for="name" class="block text-xs uppercase tracking-wide text-neutral-500 mb-1"><%= t('customCommands.name') %></label>
          <div class="flex items-center">
            <span class="text-neutral-600 px-2 select-none">!</span>
            <input type="text" id="name" name="name" required autocomplete="off"
                   pattern="[a-zA-Zа-яА-Я0-9]+"
                   class="flex-1 bg-neutral-950 border border-neutral-800 rounded-md px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-600" />
          </div>
        </div>

        <div>
          <label for="timerSeconds" class="block text-xs uppercase tracking-wide text-neutral-500 mb-1"><%= t('customCommands.timer') %></label>
          <input type="number" id="timerSeconds" name="timerSeconds" min="<%= minTimerSeconds %>" step="1"
                 placeholder="<%= t('customCommands.timerOff') %>"
                 class="w-full bg-neutral-950 border border-neutral-800 rounded-md px-3 py-2 text-sm text-neutral-200 placeholder:text-neutral-600 focus:outline-none focus:border-purple-600" />
        </div>
      </div>

      <div>
        <label for="result" class="block text-xs uppercase tracking-wide text-neutral-500 mb-1"><%= t('customCommands.response') %></label>
        <textarea id="result" name="result" rows="3" required maxlength="<%= maxResultLength %>"
                  class="w-full bg-neutral-950 border border-neutral-800 rounded-md px-3 py-2 text-sm text-neutral-200 focus:outline-none focus:border-purple-600"></textarea>
        <p class="text-xs text-neutral-600 mt-1"><%= t('customCommands.countersHint') %> <%= t('customCommands.responseHint') %></p>
      </div>

      <div>
        <label class="flex items-center gap-2 text-sm text-neutral-400 cursor-pointer mb-1">
          <input type="checkbox" id="categoryOverridesEnable" class="accent-purple-600" />
          <%= t('customCommands.categoryOverridesHeading') %>
        </label>
        <p class="text-xs text-neutral-600 mb-2"><%= t('customCommands.categoryOverridesHint') %></p>
        <div class="space-y-2" id="category-rows" data-max="<%= maxCategoryOverrides %>" hidden></div>
        <template id="category-row-template">
          <div class="grid grid-cols-1 sm:grid-cols-[10rem_minmax(0,1fr)] gap-2">
            <input type="text" name="categoryName" maxlength="<%= maxCategoryLength %>"
                   placeholder="<%= t('customCommands.categoryPlaceholder') %>"
                   class="bg-neutral-950 border border-neutral-800 rounded-md px-3 py-2 text-sm text-neutral-200 placeholder:text-neutral-600 focus:outline-none focus:border-purple-600" />
            <input type="text" name="categoryResult" maxlength="<%= maxResultLength %>"
                   placeholder="<%= t('customCommands.categoryResultPlaceholder') %>"
                   class="bg-neutral-950 border border-neutral-800 rounded-md px-3 py-2 text-sm text-neutral-200 placeholder:text-neutral-600 focus:outline-none focus:border-purple-600" />
          </div>
        </template>
        <%# No-JS fallback: the toggle + one-row-at-a-time behaviour above needs JS to add rows,
            so a JS-disabled visitor gets the old fixed set of rows instead - still fully usable,
            since parseCategoryTexts (lib/commandValidation.js) silently ignores blank rows. %>
        <noscript>
          <div class="space-y-2">
            <% for (let i = 0; i < maxCategoryOverrides; i++) { %>
              <div class="grid grid-cols-1 sm:grid-cols-[10rem_minmax(0,1fr)] gap-2">
                <input type="text" name="categoryName" maxlength="<%= maxCategoryLength %>"
                       placeholder="<%= t('customCommands.categoryPlaceholder') %>"
                       class="bg-neutral-950 border border-neutral-800 rounded-md px-3 py-2 text-sm text-neutral-200 placeholder:text-neutral-600 focus:outline-none focus:border-purple-600" />
                <input type="text" name="categoryResult" maxlength="<%= maxResultLength %>"
                       placeholder="<%= t('customCommands.categoryResultPlaceholder') %>"
                       class="bg-neutral-950 border border-neutral-800 rounded-md px-3 py-2 text-sm text-neutral-200 placeholder:text-neutral-600 focus:outline-none focus:border-purple-600" />
              </div>
            <% } %>
          </div>
        </noscript>
      </div>

      <label class="flex items-center gap-2 text-sm text-neutral-400 cursor-pointer">
        <input type="checkbox" name="pin" value="on" id="pin" class="accent-purple-600" />
        <%= t('customCommands.pin') %>
      </label>
      <%# The bot refuses timer+pin together (Twitch allows one active pin per channel, and a
          timered command re-pins on every auto-post). Say so up front instead of letting the
          server bounce the form back with an error. %>
      <p class="text-xs text-amber-600/80" id="pin-conflict" hidden><%= t('customCommands.errors.timer_and_pin') %></p>

      <label class="flex items-center gap-2 text-sm text-neutral-400 cursor-pointer">
        <input type="checkbox" name="modOnly" value="on" id="modOnly" class="accent-purple-600" />
        <%= t('customCommands.modOnly') %>
      </label>

      <div class="flex items-center gap-3 flex-wrap">
        <label class="flex items-center gap-2 text-sm text-neutral-400 cursor-pointer">
          <input type="checkbox" name="announce" value="on" id="announce" class="accent-purple-600" />
          <%= t('customCommands.announce') %>
        </label>
        <label class="flex items-center gap-2 text-sm text-neutral-500">
          <%= t('customCommands.announceColor') %>
          <select name="announceColor" id="announceColor"
                  class="bg-neutral-950 border border-neutral-800 rounded-md px-2 py-1 text-sm text-neutral-200 focus:outline-none focus:border-purple-600">
            <% announcementColors.forEach(function(color) { %>
              <option value="<%= color %>"><%= t('customCommands.color.' + color) %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <%# Announce and pin can't coexist either - an announcement is a self-contained Helix send
          with no message ID to pin (see lib/commandValidation.js). %>
      <p class="text-xs text-amber-600/80" id="announce-conflict" hidden><%= t('customCommands.errors.announce_and_pin') %></p>

      <div class="flex gap-3 pt-1">
        <button type="submit"
                class="px-4 py-2 rounded-md bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors"><%= t('customCommands.save') %></button>
        <button type="reset" id="cancel-edit" hidden
                class="px-4 py-2 rounded-md text-neutral-400 hover:text-neutral-100 text-sm transition-colors"><%= t('customCommands.cancel') %></button>
      </div>
    </form>
  </section>

  <!-- Existing commands -->
  <section>
    <h2 class="text-lg font-semibold text-neutral-100 mb-3"><%= t('customCommands.existing') %> <span class="text-neutral-600 text-sm">(<%= commands.length %>)</span></h2>

    <% if (commands.length === 0) { %>
      <p class="rounded-lg border border-neutral-800 bg-neutral-900 px-4 py-6 text-center text-neutral-600 text-sm"><%= t('customCommands.none') %></p>
    <% } else { %>
      <ul class="rounded-lg border border-neutral-800 bg-neutral-900 divide-y divide-neutral-800/70">
        <% commands.forEach(function(c) { %>
          <li class="px-4 py-3 flex items-start gap-3">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <code class="text-purple-400 font-medium">!<%= c.command %></code>
                <% if (c.enabled === false) { %>
                  <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-neutral-800 text-neutral-500 border border-neutral-700"><%= t('customCommands.disabledBadge') %></span>
                <% } %>
                <% if (c.timerSeconds) { %>
                  <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-neutral-800 text-neutral-400"><%= t('customCommands.every') %> <%= c.timerSeconds %>s</span>
                <% } %>
                <% if (c.pin) { %>
                  <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-amber-600/20 text-amber-500 border border-amber-600/30"><%= t('customCommands.pinned') %></span>
                <% } %>
                <% if (c.announce) { %>
                  <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-purple-600/20 text-purple-400 border border-purple-600/30"><%= t('customCommands.announced') %> · <%= t('customCommands.color.' + c.announceColor) %></span>
                <% } %>
                <% if (c.modOnly) { %>
                  <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-red-600/20 text-red-400 border border-red-600/30"><%= t('customCommands.modOnlyBadge') %></span>
                <% } %>
                <% if (c.categoryTexts.length) { %>
                  <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-blue-600/20 text-blue-400 border border-blue-600/30"><%= t('customCommands.categoryOverridesBadge') %> · <%= c.categoryTexts.length %></span>
                <% } %>
              </div>
              <p class="text-sm text-neutral-400 mt-1 break-words"><%= c.result %></p>
              <% if (c.categoryTexts.length) { %>
                <ul class="mt-1 space-y-0.5">
                  <% c.categoryTexts.forEach(function(ov) { %>
                    <li class="text-xs text-neutral-500 break-words"><span class="text-neutral-400 font-medium"><%= ov.category %>:</span> <%= ov.result %></li>
                  <% }) %>
                </ul>
              <% } %>
            </div>

            <div class="flex items-center gap-1 shrink-0">
              <%# Enable/disable toggle: a plain form submit (action=toggle), so it works without
                  JS too - no separate "enabled" checkbox on the create/edit form anymore. %>
              <form method="post" action="/<%= channel.channelLogin %>/settings/custom-commands/commands">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="action" value="toggle" />
                <input type="hidden" name="name" value="<%= c.command %>" />
                <button type="submit"
                        class="relative inline-flex h-5 w-9 items-center rounded-full transition-colors <%= c.enabled ? 'bg-purple-600' : 'bg-neutral-700' %>"
                        aria-pressed="<%= c.enabled ? 'true' : 'false' %>"
                        aria-label="<%= t('customCommands.toggleEnabled') %>">
                  <span class="inline-block h-3.5 w-3.5 transform rounded-full bg-white transition-transform <%= c.enabled ? 'translate-x-4' : 'translate-x-1' %>"></span>
                </button>
              </form>

              <%# Edit is client-side only: it copies the row back into the form above. The form
                  posts an upsert, so "edit" and "create" are the same request. %>
              <button type="button"
                      class="p-1.5 rounded text-neutral-500 hover:text-neutral-200 hover:bg-neutral-800 transition-colors js-edit"
                      data-name="<%= c.command %>"
                      data-result="<%= c.result %>"
                      data-timer="<%= c.timerSeconds || '' %>"
                      data-pin="<%= c.pin ? '1' : '' %>"
                      data-announce="<%= c.announce ? '1' : '' %>"
                      data-announce-color="<%= c.announceColor %>"
                      data-mod-only="<%= c.modOnly ? '1' : '' %>"
                      data-category-texts="<%= JSON.stringify(c.categoryTexts) %>"
                      aria-label="<%= t('customCommands.edit') %>"><%- include('partials/iconPencil') %></button>

              <form method="post" action="/<%= channel.channelLogin %>/settings/custom-commands/commands" class="js-delete-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="name" value="<%= c.command %>" />
                <button type="submit"
                        class="p-1.5 rounded text-neutral-500 hover:text-red-400 hover:bg-red-500/10 transition-colors"
                        aria-label="<%= t('customCommands.delete') %>"><%- include('partials/iconTrash') %></button>
              </form>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>

</main>

<script src="/js/custom-commands.js" defer></script>

<%- include('partials/foot') %>
