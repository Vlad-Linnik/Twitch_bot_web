<%- include('partials/head', { title: channel.channelLogin + ' ' + t('statistics.titleSuffix') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-5xl mx-auto px-6 py-12">
  <%- include('partials/statsHeader', { channel, broadcaster }) %>

  <%- include('partials/statsTabs', { channel, tab }) %>

  <!-- Per-moderator statistics (ModeratorStatistics rollup), sortable by every metric,
       period-switchable (?period= - server-rendered, mod-stats.js just navigates) -->
  <section class="mb-12">
    <div class="flex items-center justify-between flex-wrap gap-3 mb-3">
      <h2 class="text-lg font-semibold text-neutral-100"><%= t('statistics.modStatsHeading') %></h2>
      <div class="flex items-center gap-4 flex-wrap">
        <%# Always rendered, even with nothing to reveal right now - a control that appears and
            disappears between period switches reads as a glitch, not as a feature. %>
        <label class="flex items-center gap-2 text-xs text-neutral-500 cursor-pointer select-none">
          <span class="toggle-switch">
            <input type="checkbox" id="show-empty-mods" class="sr-only" />
            <span class="toggle-track"><span class="toggle-thumb"></span></span>
          </span>
          <%= t('statistics.showEmptyMods') %>
        </label>
        <%- include('partials/periodToggle', { periods, period, component: 'modstats' }) %>
      </div>
    </div>
    <p class="text-neutral-600 text-xs mb-3"><%= t('statistics.modStatsHint') %></p>

    <div class="rounded-lg border border-neutral-800 overflow-hidden">
      <div class="overflow-x-auto">
      <table id="mod-stats-table" class="w-full text-sm"
             data-label-chat="<%= t('statistics.axisChat') %>"
             data-label-presence="<%= t('statistics.axisPresence') %>"
             data-label-reaction="<%= t('statistics.axisReaction') %>"
             data-label-severity="<%= t('statistics.axisSeverity') %>"
             data-label-actions="<%= t('statistics.axisActions') %>">
        <thead class="bg-neutral-900 text-neutral-400">
          <tr>
            <th data-sort="name" class="text-left font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colModerator') %></th>
            <th data-sort="chat" class="text-right font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colChatActivity') %></th>
            <th data-sort="presence" class="text-right font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colStreamPresence') %></th>
            <th data-sort="reaction" class="text-right font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colReactionSpeed') %></th>
            <th data-sort="severity" class="text-right font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colSeverity') %></th>
            <th data-sort="actions" class="text-right font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colModActions') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-800">
          <% moderators.forEach(function(m) { %>
            <tr class="odd:bg-neutral-950 even:bg-neutral-900/40 hover:bg-purple-950/20"
                data-name="<%= m.userName %>"
                data-chat="<%= m.chatActivity %>"
                data-presence="<%= m.streamPresence %>"
                data-reaction="<%= m.reactionSpeed ?? '' %>"
                data-severity="<%= m.severity %>"
                data-actions="<%= m.moderationActivity %>">
              <td class="px-4 py-2 whitespace-nowrap <%= m.color ? '' : 'text-neutral-200' %>"
                  <% if (m.color) { %>style="color: <%= m.color %>"<% } %>><%= m.userName %></td>
              <td class="px-4 py-2 text-neutral-400 text-right tabular-nums"><%= m.chatActivity.toLocaleString() %></td>
              <td class="px-4 py-2 text-neutral-400 text-right tabular-nums"><%= m.streamPresence.toFixed(1) %></td>
              <td class="px-4 py-2 text-neutral-400 text-right tabular-nums"><%= m.reactionSpeed != null ? (m.reactionSpeed / 1000).toFixed(1) + 's' : '—' %></td>
              <td class="px-4 py-2 text-neutral-400 text-right tabular-nums"><%= m.severity.toFixed(2) %></td>
              <td class="px-4 py-2 text-neutral-400 text-right tabular-nums"><%= m.moderationActivity.toLocaleString() %></td>
            </tr>
          <% }) %>
          <% inactiveMods.forEach(function(m) { %>
            <%# Registered moderator with no recorded stats yet - dimmed, hidden behind the toggle %>
            <tr class="odd:bg-neutral-950 even:bg-neutral-900/40 opacity-40" data-empty="1" hidden
                data-name="<%= m.userName %>" data-chat="" data-presence="" data-reaction="" data-severity="" data-actions="">
              <%# opacity-40 on the row keeps the color muted, matching the old dimming %>
              <td class="px-4 py-2 whitespace-nowrap <%= m.color ? '' : 'text-neutral-500' %>"
                  <% if (m.color) { %>style="color: <%= m.color %>"<% } %>><%= m.userName %></td>
              <td class="px-4 py-2 text-neutral-600 text-right">—</td>
              <td class="px-4 py-2 text-neutral-600 text-right">—</td>
              <td class="px-4 py-2 text-neutral-600 text-right">—</td>
              <td class="px-4 py-2 text-neutral-600 text-right">—</td>
              <td class="px-4 py-2 text-neutral-600 text-right">—</td>
            </tr>
          <% }) %>
          <% if (moderators.length === 0 && inactiveMods.length === 0) { %>
            <tr><td colspan="6" class="px-4 py-6 text-center text-neutral-500"><%= t('statistics.noModStats') %></td></tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>
  </section>

  <!-- Floating skill pentagon, driven by mod-stats.js on row hover -->
  <div id="skill-polygon" hidden
       class="fixed z-50 pointer-events-none rounded-lg border border-neutral-700 bg-neutral-900/95 shadow-xl shadow-black/50 p-3"></div>

  <!-- Recent moderator actions (ModeratorActionLogs), ids resolved to nicknames.
       Sortable headers + action/moderator filters, all client-side over the rendered rows. -->
  <section>
    <div class="flex items-center justify-between flex-wrap gap-3 mb-3">
      <h2 class="text-lg font-semibold text-neutral-100"><%= t('statistics.recentModActions') %></h2>
      <%# Server-side filters (they narrow the find AND the page count, not just the rendered
          rows): two checkbox-dropdowns, changes fetched in place via mod-actions.json by
          mod-stats.js. Rendered even when the current page is empty - an empty FILTERED page
          is exactly where the controls to clear the filter must still exist. %>
      <div class="flex items-center gap-2 flex-wrap" id="mod-actions-filters"
           data-label-all="<%= t('statistics.filterAll') %>"
           data-label-selected="<%= t('statistics.filterSelected') %>">
        <details class="relative" id="action-filter-dropdown">
          <summary class="list-none cursor-pointer flex items-center gap-1.5 text-xs text-neutral-500 bg-neutral-900 border border-neutral-800 rounded-md px-2 py-1 hover:border-neutral-600 transition-colors select-none">
            <%= t('statistics.filterActionLabel') %>
            <span class="text-neutral-300" data-filter-summary>
              <%= filterState.actions.length > 0 ? filterState.actions.length + ' ' + t('statistics.filterSelected') : t('statistics.filterAll') %>
            </span>
            <svg width="10" height="10" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5.5 7.5L10 12l4.5-4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="absolute right-0 top-full mt-1 z-20 w-44 rounded-lg border border-neutral-800 bg-neutral-900 shadow-lg shadow-black/40 py-2">
            <% actionTypes.forEach(function(name) { %>
              <label class="flex items-center gap-2 px-3 py-1 text-xs text-neutral-300 cursor-pointer hover:bg-neutral-800/60">
                <input type="checkbox" name="actions" value="<%= name %>" class="accent-purple-600"
                       <%= filterState.actions.includes(name) ? 'checked' : '' %> />
                <%= name %>
              </label>
            <% }) %>
            <button type="button" data-filter-clear
                    class="mt-1 mx-3 text-[11px] text-neutral-500 hover:text-neutral-300 transition-colors"><%= t('statistics.filterClear') %></button>
          </div>
        </details>

        <details class="relative" id="mod-filter-dropdown">
          <summary class="list-none cursor-pointer flex items-center gap-1.5 text-xs text-neutral-500 bg-neutral-900 border border-neutral-800 rounded-md px-2 py-1 hover:border-neutral-600 transition-colors select-none">
            <%= t('statistics.filterModeratorLabel') %>
            <span class="text-neutral-300" data-filter-summary>
              <% const modSelCount = filterState.modIds.length || filterState.excludeModIds.length; %>
              <%= modSelCount > 0 ? modSelCount + ' ' + t('statistics.filterSelected') : t('statistics.filterAll') %>
            </span>
            <svg width="10" height="10" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5.5 7.5L10 12l4.5-4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="absolute right-0 top-full mt-1 z-20 w-56 rounded-lg border border-neutral-800 bg-neutral-900 shadow-lg shadow-black/40 py-2">
            <%# One list, one mode: include or exclude the checked moderators. A radio pair
                beats tri-state checkboxes - the mode is explicit and both-at-once is
                impossible to express. %>
            <div class="flex items-center gap-3 px-3 pb-2 border-b border-neutral-800 text-[11px] text-neutral-400">
              <label class="flex items-center gap-1 cursor-pointer">
                <input type="radio" name="mod-filter-mode" value="include" class="accent-purple-600"
                       <%= filterState.excludeModIds.length > 0 ? '' : 'checked' %> />
                <%= t('statistics.filterInclude') %>
              </label>
              <label class="flex items-center gap-1 cursor-pointer">
                <input type="radio" name="mod-filter-mode" value="exclude" class="accent-purple-600"
                       <%= filterState.excludeModIds.length > 0 ? 'checked' : '' %> />
                <%= t('statistics.filterExclude') %>
              </label>
            </div>
            <div class="max-h-56 overflow-y-auto pt-1">
              <% const checkedModIds = filterState.modIds.length > 0 ? filterState.modIds : filterState.excludeModIds; %>
              <% modOptions.forEach(function(m) { %>
                <label class="flex items-center gap-2 px-3 py-1 text-xs text-neutral-300 cursor-pointer hover:bg-neutral-800/60">
                  <input type="checkbox" name="mods" value="<%= m.id %>" class="accent-purple-600"
                         <%= checkedModIds.includes(String(m.id)) ? 'checked' : '' %> />
                  <span class="truncate"><%= m.name %></span>
                </label>
              <% }) %>
            </div>
            <button type="button" data-filter-clear
                    class="mt-1 mx-3 text-[11px] text-neutral-500 hover:text-neutral-300 transition-colors"><%= t('statistics.filterClear') %></button>
          </div>
        </details>
      </div>
    </div>
    <div class="rounded-lg border border-neutral-800 overflow-hidden">
      <div class="overflow-x-auto">
      <table id="mod-actions-table" class="w-full text-sm"
             data-label-noduration="<%= t('statistics.noDuration') %>"
             data-label-noactions="<%= t('statistics.noModActions') %>"
             data-label-nofiltered="<%= t('statistics.noFilteredActions') %>">
        <thead class="bg-neutral-900 text-neutral-400">
          <tr>
            <th data-sort="action" class="text-left font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colAction') %></th>
            <th data-sort="mod" class="text-left font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colModerator') %></th>
            <th data-sort="target" class="text-left font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colTarget') %></th>
            <th class="text-left font-medium px-4 py-2"><%= t('statistics.colDuration') %></th>
            <th data-sort="when" class="text-left font-medium px-4 py-2 whitespace-nowrap cursor-pointer hover:text-neutral-200 transition-colors"><%= t('statistics.colWhen') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-800" id="mod-actions-tbody">
          <% actions.forEach(function(a) { %>
            <%# data-id + data-tta drive the target-hover context popup (mod-stats.js): the
                popup is only wired up when the moderator reacted within 2 minutes of the target's
                last message, so the logged history is actually what was acted on.
                mod-stats.js rebuilds these rows from mod-actions.json - keep its buildRow()
                in sync with this markup. %>
            <tr class="odd:bg-neutral-950 even:bg-neutral-900/40"
                data-action="<%= a.action %>"
                data-mod="<%= a.modName %>"
                data-modid="<%= a.modID %>"
                data-target="<%= a.targetName %>"
                data-ts="<%= new Date(a.timestamp).getTime() %>"
                data-id="<%= a.id %>"
                data-tta="<%= a.TTA ?? '' %>">
              <td class="px-4 py-2 whitespace-nowrap font-medium <%= a.actionColorClass %>"><%= a.action %></td>
              <td class="px-4 py-2 whitespace-nowrap <%= a.modColor ? '' : 'text-neutral-400' %>"
                  <% if (a.modColor) { %>style="color: <%= a.modColor %>"<% } %>><%= a.modName %></td>
              <td class="px-4 py-2 whitespace-nowrap target-cell">
                <a href="/<%= channel.channelLogin %>/user/<%= encodeURIComponent(a.targetName) %>"
                   class="hover:underline <%= a.targetColor ? '' : 'text-neutral-400' %>"
                   <% if (a.targetColor) { %>style="color: <%= a.targetColor %>"<% } %>><%= a.targetName %></a>
              </td>
              <%# Reason didn't disappear - it moved into the tooltip of the duration cell %>
              <td class="px-4 py-2 text-neutral-400 whitespace-nowrap"<% if (a.reason) { %> title="<%= a.reason %>"<% } %>><%= a.durationLabel || t('statistics.noDuration') %></td>
              <%# Server-side value = SERVER-timezone fallback for no-JS visitors; mod-stats.js
                  re-renders this cell from data-ts in the viewer's own timezone. %>
              <td class="px-4 py-2 text-neutral-500 whitespace-nowrap"><%= new Date(a.timestamp).toLocaleString(locale === 'ru' ? 'ru-RU' : 'en-US') %></td>
            </tr>
          <% }) %>
          <% if (actions.length === 0) { %>
            <tr><td colspan="5" class="px-4 py-6 text-center text-neutral-500"><%= t('statistics.noModActions') %></td></tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>

    <%# Server-side pagination. The links are the no-JS fallback (filters preserved, so a
        filtered page 2 survives a refresh); mod-stats.js intercepts them and re-fetches the
        table in place instead - no navigation, no scroll jump. The slot always exists so the
        client can rebuild the nav after a filter change alters totalPages. %>
    <%
      const filterParams = [];
      if (filterState.actions.length > 0) filterParams.push(`actions=${encodeURIComponent(filterState.actions.join(','))}`);
      if (filterState.modIds.length > 0) filterParams.push(`mods=${encodeURIComponent(filterState.modIds.join(','))}`);
      else if (filterState.excludeModIds.length > 0) filterParams.push(`excludeMods=${encodeURIComponent(filterState.excludeModIds.join(','))}`);
      const filterSuffix = filterParams.length > 0 ? `&${filterParams.join('&')}` : '';
    %>
    <div id="mod-actions-pagination"
         data-label-prev="<%= t('statistics.pagePrev') %>"
         data-label-next="<%= t('statistics.pageNext') %>"
         data-label-page="<%= t('statistics.pageLabel') %>">
      <% if (totalPages > 1) { %>
        <% const pageUrl = (p) => `?period=${encodeURIComponent(period)}&page=${p}${filterSuffix}`; %>
        <nav class="flex items-center justify-center gap-3 mt-4 text-xs">
          <% if (page > 1) { %>
            <a href="<%= pageUrl(page - 1) %>" data-page="<%= page - 1 %>" class="px-3 py-1.5 rounded-md border border-neutral-800 text-neutral-300 hover:border-purple-600 hover:text-neutral-100 transition-colors"><%= t('statistics.pagePrev') %></a>
          <% } else { %>
            <span class="px-3 py-1.5 rounded-md border border-neutral-900 text-neutral-700 select-none"><%= t('statistics.pagePrev') %></span>
          <% } %>
          <span class="text-neutral-500 tabular-nums"><%= t('statistics.pageLabel') %> <%= page %> / <%= totalPages %></span>
          <% if (page < totalPages) { %>
            <a href="<%= pageUrl(page + 1) %>" data-page="<%= page + 1 %>" class="px-3 py-1.5 rounded-md border border-neutral-800 text-neutral-300 hover:border-purple-600 hover:text-neutral-100 transition-colors"><%= t('statistics.pageNext') %></a>
          <% } else { %>
            <span class="px-3 py-1.5 rounded-md border border-neutral-900 text-neutral-700 select-none"><%= t('statistics.pageNext') %></span>
          <% } %>
        </nav>
      <% } %>
    </div>
  </section>

  <!-- Floating ban-context popup (target-hover in the actions table), filled by mod-stats.js.
       data-* carry the translated strings so the client script stays locale-free. -->
  <div id="ban-context" hidden
       data-label-title="<%= t('statistics.ctxTitle') %>"
       data-label-none="<%= t('statistics.ctxNoMessages') %>"
       class="fixed z-50 pointer-events-none rounded-lg border border-neutral-700 bg-neutral-900/95 shadow-xl shadow-black/50 p-3 w-80 max-w-[90vw]"></div>
</main>

<script src="/js/mod-stats.js" defer></script>
<%- include('partials/foot') %>
