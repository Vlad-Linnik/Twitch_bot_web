<%- include('partials/head', { title: t('games.fallingBlocks.name') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-4xl mx-auto px-4 sm:px-6 py-6">
  <div class="mb-4 flex items-baseline justify-between gap-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-neutral-100"><%= t('games.fallingBlocks.name') %></h1>
    <a href="/games" class="text-sm text-purple-400 hover:text-purple-300 shrink-0">&larr; <%= t('games.fallingBlocks.backToGames') %></a>
  </div>

  <div class="flex flex-col sm:flex-row gap-6 items-center sm:items-start justify-center">
    <%# Leaderboard: top 10, plus the visitor's own row (with its real rank) as an
        11th line when they're ranked below the top. Row markup here must stay in
        sync with lbRow() in public/js/games/falling-blocks.js, which re-renders
        these rows from the score.json response after a game over. data-csrf is
        only present for logged-in visitors - its absence is how the client knows
        not to attempt saving. Ordered last on mobile (below the board). %>
    <aside id="fb-leaderboard"
           class="w-full sm:w-56 order-last sm:order-none rounded-xl border border-neutral-800 bg-neutral-900 p-4"
           <% if (user) { %>data-submit-url="/games/falling-blocks/score.json" data-csrf="<%= csrfToken %>"<% } %>
           data-empty-label="<%= t('games.fallingBlocks.leaderboardEmpty') %>">
      <p class="text-xs uppercase tracking-wide text-neutral-500 mb-2"><%= t('games.fallingBlocks.leaderboardTitle') %></p>
      <ol id="fb-lb-list" class="space-y-0.5">
        <% if (leaderboard.rows.length === 0) { %>
          <li class="text-sm text-neutral-500 py-1"><%= t('games.fallingBlocks.leaderboardEmpty') %></li>
        <% } %>
        <% leaderboard.rows.forEach(function(row) { %>
          <li class="flex items-baseline gap-2 text-sm py-1 px-1 rounded<%= row.isMe ? ' bg-purple-500/10' : '' %>">
            <span class="w-5 text-right tabular-nums text-neutral-500 shrink-0"><%= row.rank %></span>
            <span class="flex-1 truncate <%= row.isMe ? 'text-purple-300' : 'text-neutral-300' %>"
                  <% if (row.color) { %>style="color: <%= row.color %>"<% } %>><%= row.displayName %></span>
            <span class="tabular-nums text-neutral-100"><%= row.score %></span>
          </li>
        <% }) %>
      </ol>
      <div id="fb-lb-me" class="mt-1 pt-1 border-t border-neutral-800" <% if (!leaderboard.myRow) { %>hidden<% } %>>
        <ol id="fb-lb-me-row">
          <% if (leaderboard.myRow) { %>
            <li class="flex items-baseline gap-2 text-sm py-1 px-1 rounded bg-purple-500/10">
              <span class="w-5 text-right tabular-nums text-neutral-500 shrink-0"><%= leaderboard.myRow.rank %></span>
              <span class="flex-1 truncate text-purple-300"
                    <% if (leaderboard.myRow.color) { %>style="color: <%= leaderboard.myRow.color %>"<% } %>><%= leaderboard.myRow.displayName %></span>
              <span class="tabular-nums text-neutral-100"><%= leaderboard.myRow.score %></span>
            </li>
          <% } %>
        </ol>
      </div>
      <% if (!user) { %>
        <p class="text-xs text-neutral-500 mt-3">
          <%= t('games.fallingBlocks.loginToSave') %>
          <a href="/auth/login" class="text-purple-400 hover:text-purple-300"><%= t('nav.login') %></a>
        </p>
      <% } %>
    </aside>

    <%# The board. The overlay (start / pause / game over) sits on top of the canvas;
        all its text is server-rendered here - public/js/games/falling-blocks.js only
        toggles which pieces are visible via the data-* labels below. %>
    <div class="relative rounded-xl border border-neutral-800 bg-neutral-900 p-3 shrink-0">
      <%# Fixed internal resolution (360x600 + dpr scaling); the CSS size scales the
          board down to fit the viewport height so no scrolling is needed to see the
          whole field. w-auto keeps the 3:5 aspect from the canvas attributes. On
          mobile the layout stacks vertically anyway, so a fixed size stays. %>
      <canvas id="fb-board" width="360" height="600"
              class="block rounded-lg bg-neutral-950 w-[324px] h-[540px] sm:w-auto sm:h-[min(600px,calc(100dvh_-_11rem))]"></canvas>

      <%# Combo multiplier callout - toggled by showCombo() in falling-blocks.js
          whenever a lock clears a line on top of a previous one. %>
      <div id="fb-combo" data-label="<%= t('games.fallingBlocks.combo') %>"
           class="pointer-events-none absolute inset-x-0 top-6 text-center text-2xl font-extrabold tracking-wide text-amber-400 opacity-0 [text-shadow:0_2px_8px_rgba(0,0,0,0.6)]"></div>

      <div id="fb-overlay"
           data-title-start="<%= t('games.fallingBlocks.name') %>"
           data-title-paused="<%= t('games.fallingBlocks.paused') %>"
           data-title-over="<%= t('games.fallingBlocks.gameOver') %>"
           data-button-start="<%= t('games.fallingBlocks.start') %>"
           data-button-resume="<%= t('games.fallingBlocks.resume') %>"
           data-button-again="<%= t('games.fallingBlocks.playAgain') %>"
           data-final-score-label="<%= t('games.fallingBlocks.finalScore') %>"
           class="absolute inset-3 rounded-lg bg-neutral-950/80 backdrop-blur-sm grid place-items-center text-center">
        <div class="px-4">
          <h2 id="fb-overlay-title" class="text-xl font-semibold text-neutral-100 mb-1"></h2>
          <p id="fb-overlay-score" class="text-sm text-neutral-400 mb-4" hidden></p>
          <button type="button" id="fb-overlay-button"
                  class="px-5 py-2.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-400"></button>
        </div>
      </div>
    </div>

    <%# Shown instead of navigating away when a link is clicked mid-game (see
        falling-blocks.js's click interceptor) - browser tab close/refresh gets
        the native beforeunload prompt instead, which can't offer a save choice. %>
    <dialog id="fb-leave-confirm-dialog"
            class="w-[min(28rem,calc(100vw-2rem))] rounded-xl border border-neutral-800 bg-neutral-900 text-neutral-200 p-8 m-auto backdrop:bg-black/70 backdrop:backdrop-blur-sm">
      <h2 class="text-xl font-semibold text-neutral-100 mb-2"><%= t('games.fallingBlocks.leaveConfirmTitle') %></h2>
      <p class="text-base text-neutral-400 mb-8"><%= t('games.fallingBlocks.leaveConfirmBody') %></p>
      <div class="flex flex-wrap justify-end gap-3">
        <button type="button" id="fb-leave-cancel"
                class="px-5 py-2.5 text-base rounded-lg text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100 transition-colors"><%= t('games.fallingBlocks.leaveCancel') %></button>
        <button type="button" id="fb-leave-discard"
                class="px-5 py-2.5 text-base rounded-lg text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100 transition-colors"><%= t('games.fallingBlocks.leaveDiscard') %></button>
        <button type="button" id="fb-leave-save"
                class="px-5 py-2.5 text-base font-medium rounded-lg bg-purple-600 hover:bg-purple-500 text-white transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-400"><%= t('games.fallingBlocks.leaveSave') %></button>
      </div>
    </dialog>

    <div class="w-full sm:w-56 grid grid-cols-2 sm:grid-cols-1 gap-4">
      <div class="rounded-xl border border-neutral-800 bg-neutral-900 p-4">
        <div class="flex justify-between items-baseline mb-2">
          <span class="text-xs uppercase tracking-wide text-neutral-500"><%= t('games.fallingBlocks.score') %></span>
          <span id="fb-score" class="text-lg font-semibold text-neutral-100 tabular-nums">0</span>
        </div>
        <div class="flex justify-between items-baseline mb-2">
          <span class="text-xs uppercase tracking-wide text-neutral-500"><%= t('games.fallingBlocks.best') %></span>
          <span id="fb-best" class="text-sm text-purple-400 tabular-nums">0</span>
        </div>
        <div class="flex justify-between items-baseline mb-2">
          <span class="text-xs uppercase tracking-wide text-neutral-500"><%= t('games.fallingBlocks.lines') %></span>
          <span id="fb-lines" class="text-sm text-neutral-300 tabular-nums">0</span>
        </div>
        <div class="flex justify-between items-baseline">
          <span class="text-xs uppercase tracking-wide text-neutral-500"><%= t('games.fallingBlocks.level') %></span>
          <span id="fb-level" class="text-sm text-neutral-300 tabular-nums">1</span>
        </div>
      </div>

      <div class="rounded-xl border border-neutral-800 bg-neutral-900 p-4">
        <p class="text-xs uppercase tracking-wide text-neutral-500 mb-2"><%= t('games.fallingBlocks.next') %></p>
        <canvas id="fb-next" width="120" height="120" class="block w-24 h-24 mx-auto"></canvas>
      </div>

      <div class="rounded-xl border border-neutral-800 bg-neutral-900 p-4 col-span-2 sm:col-span-1 hidden sm:block">
        <p class="text-xs uppercase tracking-wide text-neutral-500 mb-2"><%= t('games.fallingBlocks.controlsTitle') %></p>
        <ul class="text-sm text-neutral-400 space-y-1.5">
          <li class="flex justify-between gap-2"><span><%= t('games.fallingBlocks.controlsMove') %></span><kbd class="text-xs text-neutral-300 bg-neutral-800 rounded px-1.5 py-0.5">&larr; &rarr;</kbd></li>
          <li class="flex justify-between gap-2"><span><%= t('games.fallingBlocks.controlsRotate') %></span><kbd class="text-xs text-neutral-300 bg-neutral-800 rounded px-1.5 py-0.5">&uarr; / R</kbd></li>
          <li class="flex justify-between gap-2"><span><%= t('games.fallingBlocks.controlsSoftDrop') %></span><kbd class="text-xs text-neutral-300 bg-neutral-800 rounded px-1.5 py-0.5">&darr;</kbd></li>
          <li class="flex justify-between gap-2"><span><%= t('games.fallingBlocks.controlsHardDrop') %></span><kbd class="text-xs text-neutral-300 bg-neutral-800 rounded px-1.5 py-0.5">Space</kbd></li>
          <li class="flex justify-between gap-2"><span><%= t('games.fallingBlocks.controlsPause') %></span><kbd class="text-xs text-neutral-300 bg-neutral-800 rounded px-1.5 py-0.5">P</kbd></li>
        </ul>
      </div>

      <%# Touch controls - only shown on small screens, where there's no keyboard. %>
      <div class="col-span-2 grid grid-cols-5 gap-2 sm:hidden">
        <button type="button" id="fb-touch-left" class="py-3 rounded-lg bg-neutral-800 text-neutral-200 text-lg active:bg-neutral-700" aria-label="<%= t('games.fallingBlocks.controlsMove') %>">&larr;</button>
        <button type="button" id="fb-touch-rotate" class="py-3 rounded-lg bg-neutral-800 text-neutral-200 text-lg active:bg-neutral-700" aria-label="<%= t('games.fallingBlocks.controlsRotate') %>">&#8635;</button>
        <button type="button" id="fb-touch-down" class="py-3 rounded-lg bg-neutral-800 text-neutral-200 text-lg active:bg-neutral-700" aria-label="<%= t('games.fallingBlocks.controlsSoftDrop') %>">&darr;</button>
        <button type="button" id="fb-touch-drop" class="py-3 rounded-lg bg-neutral-800 text-neutral-200 text-lg active:bg-neutral-700" aria-label="<%= t('games.fallingBlocks.controlsHardDrop') %>">&#10515;</button>
        <button type="button" id="fb-touch-right" class="py-3 rounded-lg bg-neutral-800 text-neutral-200 text-lg active:bg-neutral-700" aria-label="<%= t('games.fallingBlocks.controlsMove') %>">&rarr;</button>
      </div>
    </div>
  </div>
</main>

<script src="/js/games/falling-blocks.js" defer></script>
<%- include('partials/foot') %>
