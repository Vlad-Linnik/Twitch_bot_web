<%- include('partials/head', { title: channel.channelLogin + ' ' + t('statistics.titleSuffix') }) %>
<%- include('partials/nav') %>

<%
  const bootstrap = {
    channel: channel.channelLogin,
    locale,
    period,
    wordCloud,
    emoteCloud,
    sessions,
    streamChart,
    streamChartLabels: {
      viewers: t('statistics.streamChart.viewers'),
      messages: t('statistics.streamChart.messages'),
    },
  };
%>

<main class="pt-14 max-w-5xl mx-auto px-6 py-12">

  <%- include('partials/statsHeader', { channel, broadcaster }) %>

  <%# Chat/Moderators switcher only for visitors who can actually open the mod page. %>
  <% if (canModerate) { %>
    <%- include('partials/statsTabs', { channel, tab }) %>
  <% } %>

  <!-- Stream stats: viewers + chat rate over one stream, category segments along the bottom.
       Both series share ONE y-axis (no dual-axis) - see public/js/stream-chart.js. -->
  <section class="mb-12" data-component="streamchart">
    <div class="flex items-center justify-between mb-3 gap-4 flex-wrap">
      <h2 class="text-lg font-semibold text-neutral-100"><%= t('statistics.streamChart.title') %></h2>
      <div class="flex items-center gap-3">
        <span id="stream-live-badge" hidden
              class="text-[10px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded bg-red-500/20 text-red-400 border border-red-500/30">
          <%= t('statistics.streamChart.live') %>
        </span>
        <%# Populated entirely by JS from the boot data, in the visitor's own timezone - no
            server-rendered <option> would know the visitor's timezone, so this starts empty. %>
        <select id="stream-session-select" aria-label="<%= t('statistics.streamChart.selectStream') %>"
                class="bg-neutral-950 border border-neutral-800 rounded-md px-2 py-1 text-xs text-neutral-300 focus:outline-none focus:border-purple-600"></select>
      </div>
    </div>

    <div id="stream-chart-empty"
         class="rounded-lg border border-neutral-800 bg-neutral-900 p-6 text-center text-neutral-600 text-sm" hidden>
      <%= t('statistics.streamChart.noSessions') %>
    </div>

    <div id="stream-chart-wrap" class="rounded-lg border border-neutral-800 bg-neutral-900 p-4" hidden>
      <div class="flex items-center gap-4 mb-2 text-xs text-neutral-400">
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-0.5 rounded-full" style="background:#e66767"></span>
          <%= t('statistics.streamChart.viewers') %>
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-0.5 rounded-full" style="background:#3987e5"></span>
          <%= t('statistics.streamChart.messages') %>
        </span>
      </div>
      <div class="flex items-stretch gap-2">
        <div id="stream-chart-yaxis"
             class="w-10 shrink-0 flex flex-col justify-between items-end text-[10px] leading-none text-neutral-500 tabular-nums py-0.5"></div>
        <div class="relative flex-1 min-w-0">
          <svg id="stream-chart" class="w-full h-48" viewBox="0 0 800 200" preserveAspectRatio="none" role="img"
               aria-label="<%= t('statistics.streamChart.title') %>"></svg>
          <div id="stream-chart-tooltip"
               class="hidden absolute pointer-events-none z-10 rounded-md border border-neutral-700 bg-neutral-950/95 px-2.5 py-1.5 text-xs shadow-lg whitespace-nowrap"></div>
        </div>
      </div>
      <div id="stream-chart-xaxis"
           class="flex justify-between text-[10px] leading-none text-neutral-500 tabular-nums mt-1.5 ml-12"></div>
      <div id="stream-chart-categories" class="flex mt-2 ml-12 rounded overflow-hidden border border-neutral-800 text-[10px] h-5"></div>
    </div>
  </section>

  <section class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-12">
    <div class="rounded-lg border border-neutral-800 bg-neutral-900 p-4">
      <p class="text-neutral-500 text-xs uppercase tracking-wide"><%= t('statistics.totalMessages') %></p>
      <p class="text-2xl font-semibold text-neutral-100 mt-1"><%= totals.totalMessages.toLocaleString() %></p>
    </div>
    <div class="rounded-lg border border-neutral-800 bg-neutral-900 p-4">
      <p class="text-neutral-500 text-xs uppercase tracking-wide"><%= t('statistics.uniqueChatters') %></p>
      <p class="text-2xl font-semibold text-neutral-100 mt-1"><%= totals.uniqueChatters.toLocaleString() %></p>
    </div>
    <div class="rounded-lg border border-neutral-800 bg-neutral-900 p-4 col-span-2 sm:col-span-1">
      <p class="text-neutral-500 text-xs uppercase tracking-wide"><%= t('channelDashboard.trackedEmotes') %></p>
      <p class="text-2xl font-semibold text-neutral-100 mt-1"><%= trackedEmoteCount.toLocaleString() %></p>
    </div>
  </section>

  <!-- Channel word cloud -->
  <section class="mb-12" data-component="wordcloud">
    <div class="flex items-center justify-between mb-3 gap-4">
      <h2 class="text-lg font-semibold text-neutral-100"><%= t('channelDashboard.wordCloud') %></h2>
      <%- include('partials/periodToggle', { periods, period, component: 'wordcloud' }) %>
    </div>
    <%# relative + no padding: cloud-layout.js positions children absolutely (padding is baked
        into its own PAD constant) and grows the height past min-h as the cloud fills in. %>
    <div id="channel-word-cloud"
         class="relative overflow-hidden rounded-lg border border-neutral-800 bg-neutral-900 min-h-48"></div>
    <p class="text-xs text-neutral-600 mt-2"><%= t('channelDashboard.cloudCapNote') %></p>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-12">

    <!-- Top 10 chatters, name in the chatter's real Twitch chat color, period-switchable -->
    <section data-component="topchatters">
      <div class="flex items-center justify-between mb-3 gap-4">
        <h2 class="text-lg font-semibold text-neutral-100"><%= t('statistics.topChatters') %></h2>
        <%- include('partials/periodToggle', { periods, period: topChattersPeriod, component: 'topchatters' }) %>
      </div>
      <ol id="top-chatters"
          data-empty-text="<%= t('channelDashboard.noChatters') %>"
          class="rounded-lg border border-neutral-800 bg-neutral-900 divide-y divide-neutral-800/70">
        <% topChatters.forEach(function(u) { %>
          <% const medal = u.rank === 1 ? '👑' : u.rank === 2 ? '🥈' : u.rank === 3 ? '🥉' : null; %>
          <li class="flex items-center gap-3 px-4 py-2.5">
            <span class="w-6 shrink-0 text-center <%= medal ? 'text-base' : 'text-xs text-neutral-600 tabular-nums' %>"><%= medal || u.rank %></span>
            <a href="/<%= channel.channelLogin %>/user/<%= encodeURIComponent(u.userName) %>"
               class="hover:underline truncate flex-1 min-w-0 <%= u.rank <= 3 ? 'font-medium' : '' %> <%= u.color ? '' : 'text-neutral-200' %>"
               <% if (u.color) { %>style="color: <%= u.color %>"<% } %>><%= u.userName %></a>
            <span class="text-neutral-500 text-sm tabular-nums shrink-0"><%= u.messageCount.toLocaleString() %></span>
          </li>
        <% }) %>
        <% if (topChatters.length === 0) { %>
          <li class="px-4 py-6 text-center text-neutral-600 text-sm"><%= t('channelDashboard.noChatters') %></li>
        <% } %>
      </ol>
    </section>

    <!-- Emote cloud: real emote images (7TV / Twitch global), sized by usage, period-switchable -->
    <section data-component="emotes">
      <div class="flex items-center justify-between mb-3 gap-4">
        <h2 class="text-lg font-semibold text-neutral-100"><%= t('statistics.topEmotes') %></h2>
        <%- include('partials/periodToggle', { periods, period, component: 'emotes' }) %>
      </div>
      <div id="emote-cloud"
           class="relative overflow-hidden rounded-lg border border-neutral-800 bg-neutral-900 min-h-64"></div>
      <p id="emote-cloud-empty" class="text-xs text-neutral-600 mt-2" hidden><%= t('channelDashboard.noTrackedEmotes') %></p>
    </section>
  </div>

  <!-- Find a user: Top Chatters only links the top 10, so this is the only way to reach an
       arbitrary profile without typing the URL by hand. Suggestions cover partial/mistyped
       names - see user-search.json / statistics-chat.js. -->
  <section class="mb-10" id="user-search">
    <h2 class="text-lg font-semibold text-neutral-100 mb-3"><%= t('channelDashboard.findUser') %></h2>
    <form id="user-search-form" class="flex gap-2 rounded-lg border border-neutral-800 bg-neutral-900 p-3">
      <div class="relative flex-1 min-w-0">
        <input type="text" id="user-search-input" autocomplete="off"
               placeholder="<%= t('channelDashboard.findUserPlaceholder') %>"
               class="w-full bg-neutral-950 border border-neutral-800 rounded-md px-3 py-1.5 text-sm text-neutral-200 placeholder:text-neutral-600 focus:outline-none focus:border-purple-600" />
        <ul id="user-search-suggestions" hidden
            class="absolute left-0 right-0 top-full mt-1 rounded-md border border-neutral-800 bg-neutral-950 divide-y divide-neutral-900 text-sm max-h-64 overflow-y-auto z-10"></ul>
      </div>
      <button type="submit"
              class="px-4 py-1.5 text-sm rounded-md bg-purple-600 hover:bg-purple-500 text-white transition-colors">
        <%= t('channelDashboard.findUserButton') %>
      </button>
    </form>
  </section>

  <!-- Universal log search (moderator-only) -->
  <% if (canModerate) { %>
    <section class="mb-10" id="universal-search">
      <div class="flex items-center justify-between mb-3 gap-4">
        <h2 class="text-lg font-semibold text-neutral-100">
          <%= t('channelDashboard.logSearch') %>
          <span class="ml-2 align-middle text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-purple-600/20 text-purple-400 border border-purple-600/30"><%= t('userDashboard.modOnly') %></span>
        </h2>
        <%- include('partials/periodToggle', { periods, period, component: 'search' }) %>
      </div>

      <div class="rounded-lg border border-neutral-800 bg-neutral-900">
        <div class="p-3 border-b border-neutral-800 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <input type="search" id="search-term" autocomplete="off"
                 placeholder="<%= t('channelDashboard.searchPlaceholder') %>"
                 class="bg-neutral-950 border border-neutral-800 rounded-md px-3 py-1.5 text-sm text-neutral-200 placeholder:text-neutral-600 focus:outline-none focus:border-purple-600" />
          <input type="text" id="search-users" autocomplete="off"
                 placeholder="<%= t('channelDashboard.usersPlaceholder') %>"
                 class="bg-neutral-950 border border-neutral-800 rounded-md px-3 py-1.5 text-sm text-neutral-200 placeholder:text-neutral-600 focus:outline-none focus:border-purple-600" />
        </div>
        <div class="px-3 py-2 border-b border-neutral-800 flex items-center gap-4">
          <label class="flex items-center gap-1.5 text-xs text-neutral-500 cursor-pointer">
            <input type="checkbox" id="search-fuzzy" class="accent-purple-600" />
            <%= t('userDashboard.fuzzy') %>
          </label>
          <p id="search-status" class="text-xs text-neutral-600 flex-1 truncate"></p>
        </div>
        <ul id="search-results" class="divide-y divide-neutral-900 max-h-[28rem] overflow-y-auto text-sm"></ul>
      </div>
    </section>
  <% } %>

</main>

<%# Chat-derived strings - must not go through a bare JSON.stringify(). See lib/safeJson.js. %>
<script id="stats-chat-data" type="application/json"><%- safeJson(bootstrap) %></script>
<script src="/js/cloud-layout.js" defer></script>
<script src="/js/statistics-chat.js" defer></script>
<script src="/js/stream-chart.js" defer></script>

<%- include('partials/foot') %>
