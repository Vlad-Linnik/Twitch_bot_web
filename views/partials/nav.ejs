<%#
  Included BYTE-IDENTICALLY at the top of every page's <body> and pinned with
  view-transition-name: site-nav, so the browser treats it as the same element across
  navigations instead of animating it with the rest of the page. Do NOT give any page its own
  variant of this markup, and do not move it behind client-side routing - both break the pinning
  (see CLAUDE.md, "View transitions & nav bar").

  The dropdown is a pure CSS group/group-hover disclosure - no JS. The only script here is the
  logout confirmation, which needs a <dialog>.
%>
<nav class="site-nav fixed top-0 inset-x-0 z-50 h-14 grid grid-cols-[1fr_auto_1fr] items-center gap-2 px-3 sm:px-6 bg-neutral-950/90 backdrop-blur border-b border-neutral-800">
  <a href="/" class="justify-self-start text-sm font-semibold tracking-wide text-neutral-100 shrink-0 truncate"><%= t('nav.brand') %></a>
  <div class="justify-self-center flex items-center gap-2.5 sm:gap-6 text-xs sm:text-sm text-neutral-400 min-w-0">
    <a href="/commands" class="hover:text-neutral-100 transition-colors <%= currentPath === '/commands' ? 'text-neutral-100 font-medium' : '' %>"><%= t('nav.commands') %></a>
    <a href="/games" class="hover:text-neutral-100 transition-colors <%= currentPath === '/games' ? 'text-neutral-100 font-medium' : '' %>"><%= t('nav.games') %></a>
    <a href="/about" class="hidden sm:inline hover:text-neutral-100 transition-colors <%= currentPath === '/about' ? 'text-neutral-100 font-medium' : '' %>"><%= t('nav.about') %></a>
  </div>

  <%#
    No language switcher here any more - it lives only on /settings. Two reasons it was worth
    removing rather than duplicating: it was the only nav control that mutated state (?lang=
    triggers a cookie write + redirect on every page), and with locale now auto-detected and
    persisted on a visitor's first request (middleware/i18n.js), a permanent switcher in the
    chrome is dead weight for everyone who never changes it.
  %>
  <div class="justify-self-end flex items-center gap-2.5 sm:gap-6 text-xs sm:text-sm text-neutral-400 min-w-0">
    <% if (typeof user !== "undefined" && user) { %>
      <div class="relative group shrink-0">
        <%# The avatar IS the menu trigger. tabindex + aria make it reachable without a pointer. %>
        <button type="button"
                class="flex items-center rounded-full ring-1 ring-neutral-700 hover:ring-neutral-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-500 transition-shadow"
                aria-haspopup="true"
                aria-label="<%= user.displayName %>">
          <% if (typeof userAvatarUrl !== "undefined" && userAvatarUrl) { %>
            <img src="<%= userAvatarUrl %>" alt="" width="32" height="32" class="w-8 h-8 rounded-full block" />
          <% } else { %>
            <%# No avatar resolved (Twitch lookup failed) - a monogram beats a broken image icon. %>
            <span class="w-8 h-8 rounded-full grid place-items-center bg-neutral-800 text-neutral-300 text-sm font-semibold"><%= user.displayName.charAt(0).toUpperCase() %></span>
          <% } %>
        </button>

        <%# pt-2 keeps a hover bridge between the avatar and the panel, so the menu doesn't close
            in the gap while the pointer travels down to it. %>
        <div class="absolute right-0 top-full pt-2 hidden group-hover:block group-focus-within:block">
          <div class="w-64 rounded-lg border border-neutral-800 bg-neutral-900 shadow-lg shadow-black/40 py-2 text-sm">
            <div class="px-4 pb-2 mb-1 border-b border-neutral-800">
              <p class="font-medium truncate"
                 <% if (typeof userDisplayColor !== "undefined" && userDisplayColor) { %>style="color: <%= userDisplayColor %>"<% } %>><%= user.displayName %></p>
            </div>

            <p class="px-4 pb-1 text-neutral-500 text-xs uppercase tracking-wide"><%= t('nav.creatorDashboard') %></p>
            <% if (typeof navMenu !== "undefined" && navMenu && navMenu.channelConnected) { %>
              <div class="px-4 pb-2 flex items-center justify-between">
                <span class="text-neutral-300 truncate"><%= navMenu.ownedChannel.channelLogin %></span>
                <span class="flex gap-3 shrink-0">
                  <a href="/<%= navMenu.ownedChannel.channelLogin %>" class="text-purple-400 hover:text-purple-300"><%= t('nav.statisticsLink') %></a>
                  <a href="/<%= navMenu.ownedChannel.channelLogin %>/settings" class="text-purple-400 hover:text-purple-300"><%= t('nav.settingsLink') %></a>
                </span>
              </div>
            <% } else { %>
              <p class="px-4 pb-2 text-neutral-600 text-xs"><%= t('nav.channelNotConnected') %></p>
            <% } %>

            <div class="border-t border-neutral-800 my-1"></div>

            <p class="px-4 pt-1 pb-1 text-neutral-500 text-xs uppercase tracking-wide"><%= t('nav.channelsIModerate') %></p>
            <% if (typeof navMenu !== "undefined" && navMenu && navMenu.moderatedChannels.length > 0) { %>
              <% navMenu.moderatedChannels.forEach(function(ch) { %>
                <div class="px-4 py-1 flex items-center justify-between">
                  <span class="text-neutral-300 truncate"><%= ch.channelLogin %></span>
                  <span class="flex gap-3 shrink-0">
                    <a href="/<%= ch.channelLogin %>" class="text-purple-400 hover:text-purple-300"><%= t('nav.statisticsLink') %></a>
                    <a href="/<%= ch.channelLogin %>/settings" class="text-purple-400 hover:text-purple-300"><%= t('nav.settingsLink') %></a>
                  </span>
                </div>
              <% }) %>
            <% } else { %>
              <p class="px-4 py-1 text-neutral-600 text-xs"><%= t('nav.noModeratedChannels') %></p>
            <% } %>

            <div class="border-t border-neutral-800 my-1"></div>

            <a href="/settings" class="block px-4 py-2 text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100"><%= t('nav.settings') %></a>

            <%# Logout now lives INSIDE the panel rather than sitting in the nav bar, where it was
                a one-click destructive action permanently adjacent to ordinary navigation. %>
            <form id="logout-form" method="post" action="/auth/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="w-full text-left px-4 py-2 text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors"><%= t('nav.logout') %></button>
            </form>
          </div>
        </div>
      </div>

      <%# Bigger window, bigger type, danger-red confirm. The IDs are the contract with
          public/js/logout-confirm.js - don't rename them. %>
      <dialog id="logout-confirm-dialog"
              class="w-[min(30rem,calc(100vw-2rem))] rounded-xl border border-neutral-800 bg-neutral-900 text-neutral-200 p-8 m-auto backdrop:bg-black/70 backdrop:backdrop-blur-sm">
        <h2 class="text-xl font-semibold text-neutral-100 mb-2"><%= t('nav.logoutConfirmTitle') %></h2>
        <p class="text-base text-neutral-400 mb-8"><%= t('nav.logoutConfirmBody') %></p>
        <div class="flex justify-end gap-3">
          <button type="button" id="logout-cancel"
                  class="px-5 py-2.5 text-base rounded-lg text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100 transition-colors"><%= t('nav.logoutCancel') %></button>
          <button type="button" id="logout-confirm"
                  class="px-5 py-2.5 text-base font-medium rounded-lg bg-red-600 hover:bg-red-500 text-white transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-red-400"><%= t('nav.logoutConfirm') %></button>
        </div>
      </dialog>
      <script src="/js/logout-confirm.js" defer></script>
    <% } else { %>
      <a href="/auth/login" class="px-2.5 py-1 sm:px-3 sm:py-1.5 rounded-md bg-purple-600 hover:bg-purple-500 text-white transition-colors shrink-0 whitespace-nowrap"><%= t('nav.login') %></a>
    <% } %>
  </div>
</nav>
