<%# Sub-page switcher for /:channel/statistics/{chat,mod}. Expects: channel, tab ("chat"|"mod"). %>
<nav class="flex gap-1 mb-10 border-b border-neutral-800">
  <a href="/<%= channel.channelLogin %>/statistics/chat"
     class="px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors <%= tab === 'chat' ? 'border-purple-500 text-neutral-100' : 'border-transparent text-neutral-500 hover:text-neutral-300' %>">
    <%= t('statistics.tabChat') %>
  </a>
  <a href="/<%= channel.channelLogin %>/statistics/mod"
     class="px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors <%= tab === 'mod' ? 'border-purple-500 text-neutral-100' : 'border-transparent text-neutral-500 hover:text-neutral-300' %>">
    <%= t('statistics.tabMod') %>
  </a>
</nav>
