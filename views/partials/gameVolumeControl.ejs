<%# Shared master-volume slider for every on-site game that has sound.
    Include this partial + <script src="/js/games/gameVolume.js"> (non-deferred,
    before the game's own script) on any such game page. One persisted value
    (localStorage, public/js/games/gameVolume.js) drives every game - changing
    it on one game page carries over to the rest. %>
<div class="fixed bottom-4 right-4 z-40 flex items-center gap-2 rounded-full border border-neutral-800 bg-neutral-900/90 backdrop-blur px-3 py-2 shadow-lg">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-neutral-400 shrink-0" aria-hidden="true">
    <path d="M3 9v6h4l5 5V4L7 9H3z" />
    <path d="M16.5 12c0-1.77-.77-3.29-2-4.24v8.48c1.23-.95 2-2.47 2-4.24z" />
  </svg>
  <input type="range" min="0" max="100" step="1" value="50" data-game-volume-slider
         aria-label="<%= t('games.volume') %>"
         class="w-20 sm:w-24 accent-purple-500 cursor-pointer" />
</div>
