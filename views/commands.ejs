<%- include('partials/head', { title: 'Commands' }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-4xl mx-auto px-6 py-16">
  <h1 class="text-3xl font-bold text-neutral-100 mb-2">Available Commands</h1>
  <p class="text-neutral-500 text-sm mb-10">
    Signatures shown are defaults - each channel owner can rename them via that channel's settings page.
  </p>

  <% commandGroups.forEach(function(group) { %>
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-neutral-100 mb-3"><%= group.category %></h2>
      <div class="rounded-lg border border-neutral-800 overflow-hidden">
        <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-neutral-900 text-neutral-400">
            <tr>
              <th class="text-left font-medium px-4 py-2">Command</th>
              <th class="text-left font-medium px-4 py-2 w-28">Access</th>
              <th class="text-left font-medium px-4 py-2">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800">
            <% group.commands.forEach(function(cmd) { %>
              <tr class="odd:bg-neutral-950 even:bg-neutral-900/40">
                <td class="px-4 py-2 font-mono text-purple-300 whitespace-nowrap"><%= cmd.signature %></td>
                <td class="px-4 py-2 text-neutral-400 whitespace-nowrap"><%= cmd.access %></td>
                <td class="px-4 py-2 text-neutral-400"><%= cmd.description %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
    </section>
  <% }) %>
</main>

<%- include('partials/foot') %>
