<%- include('partials/head', { title: t('games.pong.name') }) %>
<%- include('partials/nav') %>

<main class="pt-14 max-w-3xl mx-auto px-4 sm:px-6 py-6">
  <div class="mb-4 flex items-baseline justify-between gap-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-neutral-100"><%= t('games.pong.name') %></h1>
    <a href="/games" class="text-sm text-purple-400 hover:text-purple-300 shrink-0">&larr; <%= t('games.pong.backToGames') %></a>
  </div>

  <div id="pong-root" data-ws-path="/ws/pong" class="max-w-xl mx-auto">
    <div id="pong-screen-idle" class="rounded-xl border border-neutral-800 bg-neutral-900 p-8 text-center">
      <p class="text-neutral-400 mb-4"><%= t('games.pong.intro') %></p>
      <button type="button" id="pong-queue-button"
              class="px-6 py-3 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors"><%= t('games.quickMatch.findOpponent') %></button>
      <%- include('partials/quickMatchLobby') %>
    </div>

    <div id="pong-screen-queued" hidden class="rounded-xl border border-neutral-800 bg-neutral-900 p-8 text-center">
      <p class="text-neutral-300 mb-2"><%= t('games.quickMatch.searchingForOpponent') %></p>
      <p class="text-sm text-neutral-500 mb-1"><%= t('games.quickMatch.playersSearching') %>: <span id="pong-queue-count" class="tabular-nums text-neutral-200">1</span></p>
      <p class="text-sm text-neutral-500 mb-6"><%= t('games.quickMatch.searchTime') %>: <span id="pong-queue-time" class="tabular-nums text-neutral-200">0:00</span></p>
      <button type="button" id="pong-cancel-queue"
              class="px-5 py-2.5 rounded-lg text-neutral-300 hover:bg-neutral-800 transition-colors"><%= t('games.quickMatch.cancelSearch') %></button>
    </div>

    <div id="pong-screen-game" hidden>
      <div id="pong-opponent-banner" hidden class="mb-3 px-4 py-2 rounded-lg bg-amber-500/15 text-amber-300 text-sm text-center">
        <%= t('games.quickMatch.opponentDisconnected') %>
      </div>
      <p id="pong-spectating-badge" hidden class="text-xs text-purple-400 text-center mb-2"><%= t('games.quickMatch.spectatingBadge') %></p>
      <div class="text-center mb-2">
        <span id="pong-score" class="text-2xl font-semibold text-neutral-100 tabular-nums">0 : 0 (7)</span>
      </div>
      <div class="relative rounded-xl border border-neutral-800 bg-neutral-900 p-3">
        <canvas id="pong-canvas" width="800" height="600" class="w-full h-auto rounded-lg"></canvas>
      </div>
      <p class="text-center text-xs text-neutral-500 mt-2"><%= t('games.pong.controlsHint') %></p>
      <div class="text-center mt-3">
        <button type="button" id="pong-resign"
                class="px-4 py-2 rounded-lg text-neutral-400 hover:bg-neutral-800 text-sm transition-colors"><%= t('games.quickMatch.resign') %></button>
        <button type="button" id="pong-stop-watching-btn" hidden
                class="px-4 py-2 rounded-lg text-neutral-400 hover:bg-neutral-800 text-sm transition-colors"><%= t('games.quickMatch.stopWatching') %></button>
      </div>

      <div id="pong-result" hidden class="mt-6 rounded-xl border border-neutral-800 bg-neutral-900 p-8 text-center">
        <h2 id="pong-result-title" data-win="<%= t('games.pong.youWin') %>" data-lose="<%= t('games.pong.youLose') %>"
            class="text-xl font-semibold text-neutral-100 mb-2"></h2>
        <p id="pong-result-body" data-rating-tpl="<%= t('games.quickMatch.ratingChangeTpl') %>" class="text-sm text-neutral-400 mb-4"></p>
        <button type="button" id="pong-play-again"
                class="px-5 py-2.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium transition-colors"><%= t('games.pong.playAgain') %></button>
      </div>
    </div>
  </div>

  <%# Rating leaderboard - same pattern as gameBattleship.ejs's. %>
  <aside class="max-w-sm mx-auto mt-6 rounded-xl border border-neutral-800 bg-neutral-900 p-4">
    <p class="text-xs uppercase tracking-wide text-neutral-500 mb-2"><%= t('games.pong.leaderboardTitle') %></p>
    <ol class="space-y-0.5">
      <% if (leaderboard.rows.length === 0) { %>
        <li class="text-sm text-neutral-500 py-1"><%= t('games.pong.leaderboardEmpty') %></li>
      <% } %>
      <% leaderboard.rows.forEach(function(row) { %>
        <li class="flex items-baseline gap-2 text-sm py-1 px-1 rounded<%= row.isMe ? ' bg-purple-500/10' : '' %>">
          <span class="w-5 text-right tabular-nums text-neutral-500 shrink-0"><%= row.rank %></span>
          <span class="flex-1 truncate <%= row.isMe ? 'text-purple-300' : 'text-neutral-300' %>"
                <% if (row.color) { %>style="color: <%= row.color %>"<% } %>><%= row.displayName %></span>
          <span class="tabular-nums text-neutral-100"><%= row.score %></span>
        </li>
      <% }) %>
      <% if (leaderboard.myRow) { %>
        <li class="flex items-baseline gap-2 text-sm py-1 px-1 rounded bg-purple-500/10 mt-1 pt-1 border-t border-neutral-800">
          <span class="w-5 text-right tabular-nums text-neutral-500 shrink-0"><%= leaderboard.myRow.rank %></span>
          <span class="flex-1 truncate text-purple-300"
                <% if (leaderboard.myRow.color) { %>style="color: <%= leaderboard.myRow.color %>"<% } %>><%= leaderboard.myRow.displayName %></span>
          <span class="tabular-nums text-neutral-100"><%= leaderboard.myRow.score %></span>
        </li>
      <% } %>
    </ol>
  </aside>
</main>

<%- include('partials/quickMatchReadyCheck') %>
<%- include('partials/gameVolumeControl') %>
<script src="/js/games/gameVolume.js" defer></script>
<script src="/js/games/quickMatchClient.js" defer></script>
<script src="/js/games/pong.js" defer></script>
<%- include('partials/foot') %>
